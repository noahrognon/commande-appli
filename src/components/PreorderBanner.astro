---
import { createServerClient } from "../lib/supabaseServer";

const supabase = createServerClient();
const { data } = await supabase
	.from("preorders")
	.select("id, name, end_date, status")
	.eq("status", "open")
	.limit(1)
	.maybeSingle();

const preorder = data ?? null;
const endDateStr = preorder?.end_date ? String(preorder.end_date) : "";
---

<section class="panel rounded-[1.8rem] p-5" data-preorder-root>
	{preorder ? (
		<div class="grid gap-5 lg:grid-cols-[1fr_auto] lg:items-center">
			<div class="flex items-start gap-4">
				<span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-[#28e08f] text-lg font-black text-[#101820]">⏱</span>
				<div>
					<p class="text-xs font-black uppercase tracking-[0.16em] text-[#116b4c]">Précommande ouverte</p>
					<h2 class="mt-1 text-2xl font-black tracking-tight text-[#101820]">{preorder.name}</h2>
					<p class="mt-1 text-sm text-slate-600">Réserve avant la fermeture de la vague.</p>
				</div>
			</div>

			<div class="flex flex-col gap-3 sm:flex-row sm:items-center">
				<div class="rounded-[1.4rem] bg-[#101820] px-5 py-4 text-white" data-preorder-timer data-end-date={endDateStr}>
					<p class="text-[0.65rem] font-black uppercase tracking-[0.16em] text-[#28e08f]">Temps restant</p>
					<div class="mt-1 flex items-baseline gap-1">
						<span class="text-2xl font-black" data-hours>--</span><span class="text-xs text-white/60">h</span>
						<span class="text-xl font-black">:</span>
						<span class="text-2xl font-black" data-minutes>--</span><span class="text-xs text-white/60">m</span>
						<span class="text-xl font-black">:</span>
						<span class="text-2xl font-black" data-seconds>--</span><span class="text-xs text-white/60">s</span>
					</div>
					<p class="mt-1 text-xs text-white/55" data-countdown-label>En cours</p>
				</div>
				<a href="/precommande" class="btn-primary px-5 py-3 text-sm">Réserver</a>
			</div>
		</div>
	) : (
		<div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
			<div>
				<p class="text-lg font-black text-[#101820]">Aucune précommande en cours</p>
				<p class="text-sm text-slate-600">La prochaine ouverture apparaîtra ici.</p>
			</div>
			<a href="/notifications" class="btn-secondary px-4 py-2 text-sm">Voir les notifications</a>
		</div>
	)}
	{preorder && (
		<script type="module">
			(() => {
				const timerEl = document.querySelector("[data-preorder-timer]");
				const hoursEl = timerEl?.querySelector("[data-hours]");
				const minutesEl = timerEl?.querySelector("[data-minutes]");
				const secondsEl = timerEl?.querySelector("[data-seconds]");
				const labelEl = timerEl?.querySelector("[data-countdown-label]");
				if (!timerEl || !hoursEl || !minutesEl || !secondsEl) return;
				const endDateAttr = timerEl.getAttribute("data-end-date") || "";
				let normalized = endDateAttr.trim();
				if (normalized && !normalized.includes("T") && normalized.includes(" ")) normalized = normalized.replace(" ", "T");
				if (normalized.endsWith("+00")) normalized = normalized.replace("+00", "+00:00");
				const endDate = normalized ? Date.parse(normalized) : NaN;
				if (!Number.isFinite(endDate)) {
					hoursEl.textContent = "--";
					minutesEl.textContent = "--";
					secondsEl.textContent = "--";
					if (labelEl) labelEl.textContent = "Date invalide";
					return;
				}
				const tick = () => {
					const remaining = endDate - Date.now();
					if (remaining <= 0) {
						hoursEl.textContent = "00";
						minutesEl.textContent = "00";
						secondsEl.textContent = "00";
						if (labelEl) labelEl.textContent = "Précommande terminée";
						return false;
					}
					const totalSeconds = Math.floor(remaining / 1000);
					hoursEl.textContent = String(Math.floor(totalSeconds / 3600)).padStart(2, "0");
					minutesEl.textContent = String(Math.floor((totalSeconds % 3600) / 60)).padStart(2, "0");
					secondsEl.textContent = String(totalSeconds % 60).padStart(2, "0");
					return true;
				};
				if (tick()) {
					const interval = setInterval(() => {
						if (!tick()) clearInterval(interval);
					}, 1000);
				}
			})();
		</script>
	)}
</section>
