---
const advantages = [
	{ title: "Prix lisible", desc: "Tu vois le total avant de valider." },
	{ title: "Codes promo", desc: "Les remises actives s'appliquent directement." },
	{ title: "Suivi clair", desc: "Commande, paiement et livraison restent visibles." },
	{ title: "Commande rapide", desc: "Tu peux repartir d'une ancienne commande." }
];
---

<section class="bg-[#fffdf7] px-4 py-14 sm:px-6 lg:px-8">
	<div class="mx-auto flex max-w-6xl flex-col gap-8">
		<header class="space-y-2 text-center">
			<p class="eyebrow">Avantages</p>
			<h2 class="text-3xl font-black tracking-tight text-[#101820] sm:text-4xl">L'expérience doit donner envie de revenir.</h2>
			<p class="text-sm text-slate-600 sm:text-base">Prix lisibles, suivi clair, commandes rapides.</p>
		</header>
		<div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
			{advantages.map((item) => (
				<div class="panel interactive rounded-[1.5rem] p-5">
					<div class="mb-8 h-2 w-12 rounded-full bg-[#28e08f]"></div>
					<h3 class="text-lg font-black text-[#101820]">{item.title}</h3>
					<p class="mt-2 text-sm text-slate-600">{item.desc}</p>
				</div>
			))}
		</div>
	</div>
</section>
