---
const steps = [
	{ id: "01", title: "Tu précommandes", desc: "Choisis tes goûts et ta quantité en quelques clics." },
	{ id: "02", title: "On regroupe", desc: "Les commandes sont consolidées pour optimiser l'arrivée." },
	{ id: "03", title: "Tu récupères", desc: "Tu suis l'avancement et tu reçois les infos importantes." }
];
---

<section class="bg-[#f6f4ee] px-4 py-14 sm:px-6 lg:px-8">
	<div class="mx-auto flex max-w-6xl flex-col gap-8">
		<header class="max-w-2xl space-y-2">
			<p class="eyebrow">Process</p>
			<h2 class="text-3xl font-black tracking-tight text-[#101820] sm:text-4xl">Simple à utiliser, carré à suivre.</h2>
			<p class="text-sm leading-6 text-slate-600 sm:text-base">Chaque étape est visible depuis ton espace. Tu sais ce qui est réservé, payé et prêt.</p>
		</header>
		<div class="grid grid-cols-1 gap-5 lg:grid-cols-3">
			{steps.map((step) => (
				<div class="panel interactive rounded-[1.5rem] p-6">
					<p class="text-sm font-black text-[#28e08f]">{step.id}</p>
					<h3 class="mt-6 text-xl font-black text-[#101820]">{step.title}</h3>
					<p class="mt-2 text-sm leading-6 text-slate-600">{step.desc}</p>
				</div>
			))}
		</div>
	</div>
</section>
