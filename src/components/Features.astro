---
const features = [
	"Timer de précommande en temps réel",
	"Catalogue complet des saveurs",
	"Codes promo et récapitulatif automatique",
	"Recommande rapide depuis le profil",
	"Notifications de suivi",
	"Dashboard personnalisé"
];
---

<section class="relative overflow-hidden bg-[#101820] px-4 py-14 text-white sm:px-6 lg:px-8">
	<div class="relative mx-auto flex max-w-6xl flex-col gap-8">
		<div class="space-y-2">
			<p class="text-xs font-black uppercase tracking-[0.18em] text-[#28e08f]">Fonctionnalités</p>
			<h2 class="max-w-2xl text-3xl font-black tracking-tight sm:text-4xl">Tout ce qu'il faut pour commander sans friction.</h2>
			<p class="max-w-2xl text-sm leading-6 text-white/65 sm:text-base">Le site rassure dès la première visite: ce qui est ouvert, ce qui reste à faire, et où cliquer.</p>
		</div>
		<div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
			{features.map((feature) => (
				<div class="group flex items-center gap-4 rounded-2xl border border-white/10 bg-white/[0.04] px-4 py-4 transition hover:-translate-y-1 hover:border-[#28e08f]/50 hover:bg-white/[0.07]">
					<div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-[#28e08f] text-sm font-black text-[#101820]">
						<span aria-hidden="true">✓</span>
					</div>
					<p class="text-sm font-bold text-white sm:text-base">{feature}</p>
				</div>
			))}
		</div>
	</div>
</section>
