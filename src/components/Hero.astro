---
const puffLeft = "/images/puff1.webp";
const puffRight = "/images/puff2.webp";
---

<section class="hero-puff-scene relative isolate overflow-hidden bg-[#fffdf7] text-[#101820]" data-puff-hero>
	<div class="absolute inset-0 soft-grid opacity-60"></div>
	<div class="hero-glow hero-glow-left"></div>
	<div class="hero-glow hero-glow-right"></div>

	<div class="hero-puff-stage hero-puff-stage-left" aria-hidden="true">
		<span class="hero-puff-shadow"></span>
		<img
			src={puffLeft}
			alt=""
			class="hero-puff hero-puff-left"
			loading="eager"
			decoding="async"
		/>
	</div>
	<div class="hero-puff-stage hero-puff-stage-right" aria-hidden="true">
		<span class="hero-puff-shadow"></span>
		<img
			src={puffRight}
			alt=""
			class="hero-puff hero-puff-right"
			loading="eager"
			decoding="async"
		/>
	</div>

	<div class="relative z-10 mx-auto flex min-h-[calc(100svh-4.4rem)] w-full max-w-6xl flex-col justify-center px-4 pb-12 pt-10 sm:px-6 lg:px-8">
		<div class="hero-copy mx-auto max-w-4xl text-center">
			<div class="inline-flex items-center gap-2 rounded-full border border-black/10 bg-white/75 px-3 py-2 text-xs font-black uppercase tracking-[0.18em] text-[#116b4c] shadow-sm backdrop-blur-xl">
				<span class="h-2 w-2 rounded-full bg-[#28e08f]"></span>
				<span>Precommande par vagues</span>
			</div>

			<h1 class="mt-6 text-[clamp(2.35rem,10.8vw,3.35rem)] font-black leading-[0.92] tracking-tight text-[#101820] md:text-[clamp(4.6rem,8.5vw,7rem)]">
				<span class="block">Reserve ton</span>
				<span class="block">stock avant</span>
				<span class="block">tout le</span>
				<span class="block">monde.</span>
			</h1>

			<p class="mx-auto mt-5 max-w-2xl text-base font-semibold leading-7 text-slate-600 sm:text-lg">
				Les commandes sont groupees, les gouts sont securises, les prix restent propres. Tu choisis, on centralise, tu recuperes sans courir apres le stock.
			</p>

			<div class="mt-7 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-center sm:gap-4">
				<a href="/register" class="btn-primary px-5 py-3 text-base">
					<span>Creer un compte</span>
					<span aria-hidden="true">→</span>
				</a>
				<a href="/precommande" class="btn-secondary px-5 py-3 text-base">Commander maintenant</a>
			</div>
		</div>

		<div class="hero-metrics mx-auto mt-10 grid w-full max-w-3xl grid-cols-3 gap-2 sm:gap-4">
			<div>
				<p class="text-2xl font-black sm:text-3xl">85 EUR</p>
				<p class="mt-1 text-[0.68rem] font-black uppercase tracking-[0.12em] text-slate-500">par carton</p>
			</div>
			<div>
				<p class="text-2xl font-black sm:text-3xl">10</p>
				<p class="mt-1 text-[0.68rem] font-black uppercase tracking-[0.12em] text-slate-500">gouts max</p>
			</div>
			<div>
				<p class="text-2xl font-black sm:text-3xl">24/7</p>
				<p class="mt-1 text-[0.68rem] font-black uppercase tracking-[0.12em] text-slate-500">suivi en ligne</p>
			</div>
		</div>
	</div>
</section>

<script>
	const hero = document.querySelector("[data-puff-hero]");

	if (hero instanceof HTMLElement) {
		const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
		let ticking = false;

		const update = () => {
			const rect = hero.getBoundingClientRect();
			const scrollRange = Math.max(1, hero.offsetHeight * 0.72);
			const progress = Math.min(1, Math.max(0, -rect.top / scrollRange));

			const clamp = (value, min = 0, max = 1) => Math.min(max, Math.max(min, value));
			const smooth = (start, end, value) => {
				const t = clamp((value - start) / (end - start));
				return t * t * (3 - 2 * t);
			};

			const approach = smooth(0.02, 0.34, progress);
			const turn = smooth(0.12, 0.58, progress);
			const exit = smooth(0.62, 1, progress);
			const breathe = Math.sin(progress * Math.PI) * 0.35;

			const leftX = approach * 4.4 - exit * 12;
			const rightX = -approach * 4.4 + exit * 12;
			const leftY = -approach * 0.45 + exit * 2.9 - breathe;
			const rightY = -approach * 0.2 - exit * 2.4 + breathe;
			const leftZ = -9 + turn * 15 - exit * 20;
			const rightZ = 9 - turn * 15 + exit * 20;
			const leftYRot = -turn * 34 + exit * 18;
			const rightYRot = turn * 34 - exit * 18;
			const scale = 1 + approach * 0.08 - exit * 0.12;
			const opacity = 0.92 - exit * 0.58;
			const shadowOpacity = 0.18 + approach * 0.17 - exit * 0.24;
			const shadowScale = 1 + approach * 0.22 - exit * 0.28;

			hero.style.setProperty("--left-x", `${leftX.toFixed(2)}vw`);
			hero.style.setProperty("--left-y", `${leftY.toFixed(2)}rem`);
			hero.style.setProperty("--left-z", `${leftZ.toFixed(2)}deg`);
			hero.style.setProperty("--left-yrot", `${leftYRot.toFixed(2)}deg`);
			hero.style.setProperty("--right-x", `${rightX.toFixed(2)}vw`);
			hero.style.setProperty("--right-y", `${rightY.toFixed(2)}rem`);
			hero.style.setProperty("--right-z", `${rightZ.toFixed(2)}deg`);
			hero.style.setProperty("--right-yrot", `${rightYRot.toFixed(2)}deg`);
			hero.style.setProperty("--puff-xrot", `${(turn * 8 - exit * 5).toFixed(2)}deg`);
			hero.style.setProperty("--puff-scale", scale.toFixed(3));
			hero.style.setProperty("--puff-opacity", opacity.toFixed(3));
			hero.style.setProperty("--shadow-opacity", shadowOpacity.toFixed(3));
			hero.style.setProperty("--shadow-scale", shadowScale.toFixed(3));
			ticking = false;
		};

		const requestUpdate = () => {
			if (reduceMotion || ticking) return;
			ticking = true;
			window.requestAnimationFrame(update);
		};

		update();
		window.addEventListener("scroll", requestUpdate, { passive: true });
		window.addEventListener("resize", requestUpdate);
	}
</script>

<style>
	.hero-puff-scene {
		--left-x: 0vw;
		--left-y: 0rem;
		--left-z: -9deg;
		--left-yrot: 0deg;
		--right-x: 0vw;
		--right-y: 0rem;
		--right-z: 9deg;
		--right-yrot: 0deg;
		--puff-xrot: 0deg;
		--puff-scale: 1;
		--puff-opacity: 0.92;
		--shadow-opacity: 0.18;
		--shadow-scale: 1;
		min-height: calc(100svh - 4.4rem);
		perspective: 900px;
	}

	.hero-glow {
		position: absolute;
		inset: auto;
		width: 18rem;
		height: 18rem;
		border-radius: 999px;
		filter: blur(46px);
		opacity: 0.28;
		pointer-events: none;
	}

	.hero-glow-left {
		left: -7rem;
		top: 18%;
		background: rgba(40, 224, 143, 0.58);
	}

	.hero-glow-right {
		right: -8rem;
		top: 9%;
		background: rgba(36, 87, 255, 0.34);
	}

	.hero-puff-stage {
		position: absolute;
		z-index: 1;
		width: clamp(24rem, 44vw, 36rem);
		aspect-ratio: 1;
		pointer-events: none;
		user-select: none;
		will-change: transform;
		transform-style: preserve-3d;
	}

	.hero-puff-stage-left {
		left: -4.5rem;
		top: 12%;
		transform:
			translate3d(var(--left-x), var(--left-y), 0)
			rotateZ(var(--left-z))
			rotateY(var(--left-yrot))
			rotateX(var(--puff-xrot))
			scale(var(--puff-scale));
	}

	.hero-puff-stage-right {
		right: -4.5rem;
		bottom: 15%;
		transform:
			translate3d(var(--right-x), var(--right-y), 0)
			rotateZ(var(--right-z))
			rotateY(var(--right-yrot))
			rotateX(var(--puff-xrot))
			scale(var(--puff-scale));
	}

	.hero-puff {
		position: relative;
		z-index: 2;
		display: block;
		width: 100%;
		height: auto;
		opacity: var(--puff-opacity);
		filter: drop-shadow(0 2rem 2.4rem rgba(16, 24, 32, 0.2));
		will-change: transform, opacity;
	}

	.hero-puff-left {
		animation: puff-left-idle 5.8s cubic-bezier(0.4, 0, 0.2, 1) infinite;
	}

	.hero-puff-right {
		animation: puff-right-idle 6.4s cubic-bezier(0.4, 0, 0.2, 1) infinite;
	}

	.hero-puff-shadow {
		position: absolute;
		left: 36%;
		bottom: 10%;
		z-index: 1;
		width: 29%;
		height: 5.5%;
		border-radius: 999px;
		background: radial-gradient(ellipse, rgba(16, 24, 32, 0.42), rgba(16, 24, 32, 0.08) 62%, transparent 72%);
		filter: blur(8px);
		opacity: var(--shadow-opacity);
		transform: translate3d(0, 0.65rem, -1px) scaleX(var(--shadow-scale));
		transform-origin: center;
		will-change: transform, opacity;
	}

	.hero-metrics {
		position: relative;
		z-index: 12;
		width: min(100%, calc(100vw - 2rem));
		border-top: 1px solid rgba(16, 24, 32, 0.1);
		padding-top: 1rem;
		text-align: center;
	}

	.hero-copy {
		width: min(100%, calc(100vw - 2rem));
	}

	.hero-metrics > div + div {
		border-left: 1px solid rgba(16, 24, 32, 0.1);
	}

	@keyframes puff-left-idle {
		0%,
		100% {
			transform: translate3d(0, 0, 0) rotateZ(-1deg);
		}
		50% {
			transform: translate3d(0, -0.65rem, 0) rotateZ(1.4deg);
		}
	}

	@keyframes puff-right-idle {
		0%,
		100% {
			transform: translate3d(0, 0, 0) rotateZ(1deg);
		}
		50% {
			transform: translate3d(0, 0.75rem, 0) rotateZ(-1.2deg);
		}
	}

	@media (max-width: 767px) {
		.hero-puff-scene {
			min-height: calc(100svh - 3.6rem);
		}

		.hero-puff-stage {
			width: clamp(13.8rem, 60vw, 15rem);
		}

		.hero-puff {
			filter: drop-shadow(0 1.4rem 1.6rem rgba(16, 24, 32, 0.18));
		}

		.hero-puff-stage-left {
			left: -4.15rem;
			top: 9%;
		}

		.hero-puff-stage-right {
			right: -2.9rem;
			bottom: 56%;
		}

		.hero-metrics {
			margin-top: 2rem;
		}

		.hero-copy .btn-primary,
		.hero-copy .btn-secondary {
			width: min(100%, calc(100vw - 2rem));
			max-width: calc(100vw - 2rem);
		}
	}

	@media (min-width: 768px) {
		.hero-puff-stage-left {
			top: 13%;
		}

		.hero-puff-stage-right {
			bottom: 9%;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.hero-puff {
			animation: none;
		}

		.hero-puff-stage {
			transform: none;
		}
	}
</style>
