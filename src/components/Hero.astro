---
const metrics = [
	{ value: "85 EUR", label: "par carton" },
	{ value: "10", label: "gouts max" },
	{ value: "24/7", label: "suivi client" }
];

const processSteps = [
	{ id: "01", title: "Tu reserves", text: "Choisis tes gouts, tes quantites et ton paiement." },
	{ id: "02", title: "On centralise", text: "Les commandes sont regroupees proprement cote admin." },
	{ id: "03", title: "Tu suis", text: "Le statut avance dans ton espace sans avoir a demander." }
];

const proofCards = [
	{ title: "Preuve virement", text: "Visible pour le client et pour l'admin." },
	{ title: "Validation admin", text: "Paiement valide ou preuve refusee avec raison." },
	{ title: "Emails automatiques", text: "Commande, paiement, rappel et suivi restent propres." }
];

const advantages = [
	{ title: "Prix lisible", text: "Le total reste clair avant la validation." },
	{ title: "Commande rapide", text: "Le parcours garde le client dans le flow." },
	{ title: "Suivi clair", text: "Chaque statut est visible dans le dashboard." },
	{ title: "Admin mobile", text: "Les actions importantes restent accessibles sur telephone." }
];

const features = [
	"Timer de precommande en temps reel",
	"Catalogue complet des saveurs",
	"Codes promo et recap automatique",
	"Preuve bancaire visible",
	"Notifications de suivi",
	"Dashboard personnalise"
];
---

<section class="puff-scroll-story" data-puff-story>
	<div class="puff-stage" aria-hidden="true">
		<div class="story-surface"></div>
		<div class="story-grid"></div>
		<div class="story-depth story-depth-a"></div>
		<div class="story-depth story-depth-b"></div>
		<div class="story-depth story-depth-c"></div>
		<canvas class="puff-canvas" data-puff-canvas></canvas>
		<span class="puff-model-shadow" data-puff-shadow></span>
		<div class="story-progress">
			<span data-story-meter></span>
		</div>
	</div>

	<div class="story-steps">
		<section class="story-step story-step-hero" data-story-step>
			<div class="story-hero-copy">
				<p class="story-kicker">
					<span></span>
					Precommande par vagues
				</p>
				<h1>Reserve ton stock avant tout le monde.</h1>
				<p class="story-lead">
					Les commandes sont groupees, les gouts sont securises, les prix restent propres. Tu choisis, on centralise, tu recuperes sans courir apres le stock.
				</p>
				<div class="story-actions">
					<a href="/register" class="btn-primary story-action">
						<span>Creer un compte</span>
						<span aria-hidden="true">&#8594;</span>
					</a>
					<a href="/precommande" class="btn-secondary story-action">Commander maintenant</a>
				</div>
				<div class="story-metrics">
					{metrics.map((metric) => (
						<div>
							<strong>{metric.value}</strong>
							<span>{metric.label}</span>
						</div>
					))}
				</div>
			</div>
			<div class="story-next-hint">
				<span>Le produit accompagne toute la page</span>
			</div>
		</section>

		<section class="story-step story-step-left" data-story-step>
			<div class="story-panel">
				<p class="story-label">01 / Arrivee</p>
				<h2>Le produit entre dans la vague.</h2>
				<p>
					La page ne commence plus par une simple image. Le GLB arrive, pivote, descend et guide le regard vers la suite du parcours.
				</p>
			</div>
		</section>

		<section class="story-step story-step-process" data-story-step>
			<div class="story-panel story-panel-soft">
				<p class="story-label">02 / Process</p>
				<h2>Trois actions, rien de flou.</h2>
				<p>
					Le client comprend rapidement quoi faire, ce que vous gerez, et comment il retrouvera sa commande ensuite.
				</p>
			</div>
			<div class="story-card-stack">
				{processSteps.map((step) => (
					<article>
						<span>{step.id}</span>
						<h3>{step.title}</h3>
						<p>{step.text}</p>
					</article>
				))}
			</div>
		</section>

		<section class="story-step story-step-right" data-story-step>
			<div class="story-panel story-panel-accent">
				<p class="story-label">03 / Paiement</p>
				<h2>Le paiement reste propre, meme sur mobile.</h2>
				<p>
					Virement, liquide, preuve bancaire et validation admin sont presentes dans le parcours sans creer de confusion.
				</p>
			</div>
		</section>

		<section class="story-step story-step-depth" data-story-step>
			<div class="depth-copy">
				<p class="story-label">04 / Controle</p>
				<h2>Tout ce qui rassure est visible.</h2>
				<p>
					Le produit traverse la page pendant que les blocs importants apparaissent autour de lui : preuve, validation, emails et suivi.
				</p>
			</div>
			<div class="depth-cards">
				{proofCards.map((card) => (
					<article>
						<h3>{card.title}</h3>
						<p>{card.text}</p>
					</article>
				))}
			</div>
		</section>

		<section class="story-step story-step-left" data-story-step>
			<div class="story-panel">
				<p class="story-label">05 / Timeline</p>
				<h2>Le client sait ou sa commande en est.</h2>
				<p>
					Commande creee, paiement en attente, paiement valide, commande fournisseur, stock recu puis livraison : le statut devient une vraie experience.
				</p>
				<div class="mini-timeline">
					<span>Creee</span>
					<span>Payee</span>
					<span>Fournisseur</span>
					<span>Livree</span>
				</div>
			</div>
		</section>

		<section class="story-step story-step-advantages" data-story-step>
			<div class="wide-copy">
				<p class="story-label">06 / Avantages</p>
				<h2>L'experience doit donner envie de revenir.</h2>
			</div>
			<div class="advantage-grid">
				{advantages.map((item) => (
					<article>
						<span></span>
						<h3>{item.title}</h3>
						<p>{item.text}</p>
					</article>
				))}
			</div>
		</section>

		<section class="story-step story-step-features" data-story-step>
			<div class="feature-panel">
				<p class="story-label">07 / Fonctionnalites</p>
				<h2>Tout ce qu'il faut pour commander sans friction.</h2>
				<p>
					La home garde un cote spectaculaire, mais chaque bloc sert le parcours reel : commander, payer, suivre, recuperer.
				</p>
				<div class="feature-grid">
					{features.map((feature) => (
						<div>
							<span aria-hidden="true">&#10003;</span>
							<p>{feature}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<section class="story-step story-step-cta" data-story-step>
			<div class="story-final">
				<p class="story-label">08 / Action</p>
				<h2>La vague est prete, il reste juste a commander.</h2>
				<p>
					Le GLB termine sa trajectoire proche du CTA pour fermer l'histoire : le produit a accompagne toute la page, pas seulement le premier ecran.
				</p>
				<div class="story-actions">
					<a href="/precommande" class="btn-primary story-action">
						<span>Lancer ma precommande</span>
						<span aria-hidden="true">&#8594;</span>
					</a>
					<a href="/login" class="btn-secondary story-action">Voir mon espace</a>
				</div>
			</div>
		</section>
	</div>
</section>

<script>
	import * as THREE from "three";
	import { GLTFLoader } from "three/examples/jsm/loaders/GLTFLoader.js";
	import { RoomEnvironment } from "three/examples/jsm/environments/RoomEnvironment.js";

	const root = document.querySelector("[data-puff-story]");

	if (root instanceof HTMLElement) {
		const canvas = root.querySelector("[data-puff-canvas]");
		const stage = root.querySelector(".puff-stage");
		const meter = root.querySelector("[data-story-meter]");
		const shadow = root.querySelector("[data-puff-shadow]");
		const steps = [...root.querySelectorAll("[data-story-step]")];
		const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
		const webglAvailable = (() => {
			try {
				const testCanvas = document.createElement("canvas");
				return Boolean(
					window.WebGLRenderingContext &&
						(testCanvas.getContext("webgl") || testCanvas.getContext("experimental-webgl"))
				);
			} catch {
				return false;
			}
		})();

		if (!(canvas instanceof HTMLCanvasElement) || reducedMotion || !webglAvailable) {
			root.classList.add("is-no-3d");
		} else {
			const renderer = new THREE.WebGLRenderer({
				canvas,
				alpha: true,
				antialias: !window.matchMedia("(max-width: 767px)").matches,
				powerPreference: "high-performance"
			});

			const scene = new THREE.Scene();
			const camera = new THREE.PerspectiveCamera(32, 1, 0.1, 100);
			const modelGroup = new THREE.Group();
			const clock = new THREE.Clock();
			const pmrem = new THREE.PMREMGenerator(renderer);
			let rafId = 0;
			let modelLoaded = false;
			let destroyed = false;
			let progress = 0;
			let isMobile = window.matchMedia("(max-width: 767px)").matches;

			const state = { x: 0, y: 0, z: 0, rx: 0, ry: 0, rz: 0, scale: 1, opacity: 1 };
			const target = { ...state };
			const materials = [];

			scene.add(modelGroup);
			scene.environment = pmrem.fromScene(new RoomEnvironment(), 0.04).texture;

			const ambient = new THREE.HemisphereLight(0xffffff, 0xd7efe5, 2.35);
			const key = new THREE.DirectionalLight(0xffffff, 4.4);
			const rim = new THREE.DirectionalLight(0x8fd8ff, 2.3);
			const fill = new THREE.DirectionalLight(0xfff0be, 1.8);
			key.position.set(3.2, 4.4, 5.4);
			rim.position.set(-4.5, 2.2, -3.2);
			fill.position.set(0.6, -1.2, 3.6);
			scene.add(ambient, key, rim, fill);

			const clamp = (value, min = 0, max = 1) => Math.min(max, Math.max(min, value));
			const lerp = (from, to, amount) => from + (to - from) * amount;
			const smoother = (value) => value * value * (3 - 2 * value);
			const mixFrame = (a, b, localProgress) => {
				const t = smoother(clamp(localProgress));
				return {
					x: lerp(a.x, b.x, t),
					y: lerp(a.y, b.y, t),
					z: lerp(a.z, b.z, t),
					rx: lerp(a.rx, b.rx, t),
					ry: lerp(a.ry, b.ry, t),
					rz: lerp(a.rz, b.rz, t),
					scale: lerp(a.scale, b.scale, t),
					opacity: lerp(a.opacity, b.opacity, t)
				};
			};

			const getFrames = () => {
				if (isMobile) {
					return [
						{ p: 0, x: 0.78, y: 0.82, z: 0, rx: 0.1, ry: -0.65, rz: -0.12, scale: 0.68, opacity: 0.98 },
						{ p: 0.1, x: 0.24, y: 0.48, z: 0.06, rx: -0.03, ry: 0.25, rz: 0.08, scale: 0.86, opacity: 1 },
						{ p: 0.22, x: -0.24, y: 0.12, z: 0.14, rx: 0.08, ry: 1.18, rz: 0.17, scale: 0.98, opacity: 1 },
						{ p: 0.34, x: 0.22, y: -0.24, z: -0.02, rx: -0.1, ry: 2.05, rz: -0.1, scale: 0.93, opacity: 1 },
						{ p: 0.47, x: -0.2, y: -0.56, z: 0.1, rx: 0.08, ry: 3.18, rz: 0.16, scale: 1.03, opacity: 1 },
						{ p: 0.6, x: 0.24, y: -0.82, z: -0.04, rx: -0.06, ry: 4.18, rz: -0.13, scale: 0.9, opacity: 0.98 },
						{ p: 0.74, x: -0.16, y: -1.03, z: 0.08, rx: 0.04, ry: 5.1, rz: 0.1, scale: 0.82, opacity: 0.94 },
						{ p: 0.88, x: 0.2, y: -1.16, z: -0.1, rx: 0.1, ry: 5.92, rz: -0.16, scale: 0.74, opacity: 0.88 },
						{ p: 1, x: 0.55, y: -1.28, z: -0.18, rx: 0.14, ry: 6.55, rz: -0.24, scale: 0.62, opacity: 0.72 }
					];
				}

				return [
					{ p: 0, x: 2.05, y: 0.78, z: 0, rx: 0.08, ry: -0.72, rz: -0.12, scale: 0.82, opacity: 0.98 },
					{ p: 0.1, x: 0.94, y: 0.36, z: 0.08, rx: -0.02, ry: 0.22, rz: 0.05, scale: 1.02, opacity: 1 },
					{ p: 0.22, x: -0.78, y: 0.04, z: 0.2, rx: 0.06, ry: 1.22, rz: 0.14, scale: 1.18, opacity: 1 },
					{ p: 0.34, x: 0.68, y: -0.32, z: -0.08, rx: -0.08, ry: 2.12, rz: -0.1, scale: 1.03, opacity: 1 },
					{ p: 0.47, x: -0.56, y: -0.68, z: 0.18, rx: 0.07, ry: 3.22, rz: 0.16, scale: 1.14, opacity: 1 },
					{ p: 0.6, x: 0.55, y: -0.98, z: -0.08, rx: -0.04, ry: 4.1, rz: -0.12, scale: 0.98, opacity: 0.98 },
					{ p: 0.74, x: -0.3, y: -1.18, z: 0.14, rx: 0.04, ry: 5.05, rz: 0.08, scale: 0.88, opacity: 0.94 },
					{ p: 0.88, x: 0.44, y: -1.32, z: -0.12, rx: 0.1, ry: 5.86, rz: -0.16, scale: 0.8, opacity: 0.88 },
					{ p: 1, x: 1.08, y: -1.48, z: -0.24, rx: 0.14, ry: 6.55, rz: -0.24, scale: 0.66, opacity: 0.74 }
				];
			};

			const frameForProgress = (value) => {
				const frames = getFrames();
				for (let index = 0; index < frames.length - 1; index += 1) {
					const current = frames[index];
					const next = frames[index + 1];
					if (value <= next.p) {
						return mixFrame(current, next, (value - current.p) / (next.p - current.p));
					}
				}
				return frames[frames.length - 1];
			};

			const resize = () => {
				isMobile = window.matchMedia("(max-width: 767px)").matches;
				const width = Math.max(1, root.clientWidth);
				const height = Math.max(1, window.innerHeight);
				const pixelRatio = Math.min(window.devicePixelRatio || 1, isMobile ? 1.35 : 1.75);
				renderer.setPixelRatio(pixelRatio);
				renderer.setSize(width, height, false);
				camera.aspect = width / height;
				camera.fov = isMobile ? 35 : 30;
				camera.position.set(0, 0, isMobile ? 5.9 : 6.2);
				camera.updateProjectionMatrix();
			};

			const updateProgress = () => {
				const rect = root.getBoundingClientRect();
				const scrollRange = Math.max(1, root.offsetHeight - window.innerHeight);
				progress = clamp(-rect.top / scrollRange);
				const storyActive = rect.bottom > 0 && rect.top < window.innerHeight;
				root.classList.toggle("is-story-active", storyActive);
				if (stage instanceof HTMLElement) {
					stage.style.opacity = storyActive ? "1" : "0";
					stage.style.visibility = storyActive ? "visible" : "hidden";
				}

				const next = frameForProgress(progress);
				Object.assign(target, next);

				if (meter instanceof HTMLElement) {
					meter.style.transform = `scaleY(${progress.toFixed(4)})`;
				}

				if (shadow instanceof HTMLElement) {
					const shadowX = isMobile ? lerp(76, 72, progress) : lerp(82, 76, progress);
					const shadowY = isMobile ? lerp(34, 88, progress) : lerp(38, 86, progress);
					const shadowScale = lerp(isMobile ? 0.58 : 0.78, 0.42, progress);
					const shadowOpacity = lerp(0.2, 0.08, progress);
					shadow.style.setProperty("--shadow-x", `${shadowX.toFixed(2)}%`);
					shadow.style.setProperty("--shadow-y", `${shadowY.toFixed(2)}%`);
					shadow.style.setProperty("--shadow-scale", shadowScale.toFixed(3));
					shadow.style.setProperty("--shadow-opacity", shadowOpacity.toFixed(3));
				}
			};

			const setActiveStep = () => {
				let closest = steps[0];
				let closestDistance = Number.POSITIVE_INFINITY;
				const midpoint = window.innerHeight * 0.5;

				for (const step of steps) {
					const distance = Math.abs(step.getBoundingClientRect().top - midpoint);
					if (distance < closestDistance) {
						closestDistance = distance;
						closest = step;
					}
				}

				for (const step of steps) {
					step.classList.toggle("is-active", step === closest);
				}
			};

			const revealModel = () => {
				modelLoaded = true;
				root.dataset.modelState = "loaded";
				root.classList.add("is-loaded");
				root.classList.remove("is-no-3d");
				updateProgress();
				Object.assign(state, target);
			};

			const loader = new GLTFLoader();

			const loadModel = () => {
				root.dataset.modelState = "loading";
				loader.load(
					"/models/puff.glb",
					(gltf) => {
						const model = gltf.scene;
						const box = new THREE.Box3().setFromObject(model);
						const center = box.getCenter(new THREE.Vector3());
						const size = box.getSize(new THREE.Vector3());
						const maxAxis = Math.max(size.x, size.y, size.z) || 1;
						const baseScale = (isMobile ? 2.3 : 2.78) / maxAxis;

						model.position.sub(center);
						model.scale.setScalar(baseScale);
						model.traverse((node) => {
							if (node.isMesh) {
								node.frustumCulled = false;
								const meshMaterials = Array.isArray(node.material) ? node.material : [node.material];
								for (const material of meshMaterials) {
									if (!material) continue;
									material.transparent = true;
									material.opacity = 1;
									material.needsUpdate = true;
									materials.push(material);
								}
							}
						});

						modelGroup.add(model);
						revealModel();
					},
					(event) => {
						if (event.total > 0) {
							root.dataset.modelProgress = `${Math.round((event.loaded / event.total) * 100)}`;
						}
					},
					() => {
						root.dataset.modelState = "error";
						root.classList.add("is-no-3d");
					}
				);
			};

			loadModel();

			const render = () => {
				if (destroyed) return;
				updateProgress();

				const delta = Math.min(clock.getDelta(), 0.05);
				const damping = 1 - Math.pow(0.0008, delta);
				state.x = lerp(state.x, target.x, damping);
				state.y = lerp(state.y, target.y, damping);
				state.z = lerp(state.z, target.z, damping);
				state.rx = lerp(state.rx, target.rx, damping);
				state.ry = lerp(state.ry, target.ry, damping);
				state.rz = lerp(state.rz, target.rz, damping);
				state.scale = lerp(state.scale, target.scale, damping);
				state.opacity = lerp(state.opacity, target.opacity, damping);

				const elapsed = clock.elapsedTime;
				const idleY = Math.sin(elapsed * 1.25) * (isMobile ? 0.045 : 0.055);
				const idleRot = Math.sin(elapsed * 0.75) * 0.035;
				modelGroup.position.set(state.x, state.y + idleY, state.z);
				modelGroup.rotation.set(state.rx + idleRot * 0.35, state.ry + idleRot, state.rz + idleRot * 0.65);
				modelGroup.scale.setScalar(state.scale);

				for (const material of materials) {
					material.opacity = state.opacity;
				}

				if (modelLoaded) {
					canvas.style.opacity = String(clamp(state.opacity, 0.32, 1));
				}

				renderer.render(scene, camera);
				rafId = window.requestAnimationFrame(render);
			};

			resize();
			updateProgress();
			setActiveStep();
			renderer.setClearColor(0x000000, 0);
			renderer.outputColorSpace = THREE.SRGBColorSpace;
			renderer.toneMapping = THREE.ACESFilmicToneMapping;
			renderer.toneMappingExposure = 1.08;
			rafId = window.requestAnimationFrame(render);

			window.addEventListener("resize", resize);
			window.addEventListener("scroll", setActiveStep, { passive: true });

			window.addEventListener("pagehide", () => {
				destroyed = true;
				window.cancelAnimationFrame(rafId);
				renderer.dispose();
				pmrem.dispose();
				scene.environment?.dispose?.();
			});
		}
	}
</script>

<style>
	.puff-scroll-story {
		position: relative;
		isolation: isolate;
		min-height: 990svh;
		overflow: visible;
		background:
			linear-gradient(180deg, rgba(255, 253, 247, 0.98) 0%, rgba(246, 244, 238, 1) 52%, rgba(255, 253, 247, 1) 100%),
			linear-gradient(135deg, rgba(40, 224, 143, 0.12), transparent 34%),
			linear-gradient(315deg, rgba(36, 87, 255, 0.1), transparent 38%);
		color: #101820;
	}

	.puff-stage {
		position: fixed;
		inset: 0;
		z-index: 0;
		height: 100svh;
		overflow: hidden;
		opacity: 0;
		pointer-events: none;
		visibility: hidden;
		transition:
			opacity 0.25s ease,
			visibility 0.25s ease;
	}

	.puff-scroll-story.is-story-active .puff-stage {
		opacity: 1;
		visibility: visible;
	}

	.story-surface,
	.story-grid,
	.story-depth,
	.puff-canvas,
	.puff-model-shadow {
		position: absolute;
		pointer-events: none;
	}

	.story-surface {
		inset: 0;
		background:
			linear-gradient(90deg, rgba(255, 253, 247, 0.94) 0%, rgba(255, 253, 247, 0.54) 42%, rgba(255, 253, 247, 0.9) 100%),
			linear-gradient(180deg, rgba(16, 24, 32, 0.04), transparent 18%, rgba(16, 24, 32, 0.05) 100%);
	}

	.story-grid {
		inset: 0;
		opacity: 0.42;
		background-image:
			linear-gradient(rgba(16, 24, 32, 0.055) 1px, transparent 1px),
			linear-gradient(90deg, rgba(16, 24, 32, 0.055) 1px, transparent 1px);
		background-size: 42px 42px;
		mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.88), rgba(0, 0, 0, 0.18));
	}

	.story-depth {
		z-index: 1;
		border: 1px solid rgba(16, 24, 32, 0.08);
		background: rgba(255, 255, 255, 0.28);
		box-shadow: 0 24px 70px rgba(16, 24, 32, 0.08);
		transform: rotate(-7deg);
	}

	.story-depth-a {
		left: 7%;
		top: 18%;
