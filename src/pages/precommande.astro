---
import Layout from "../layouts/Layout.astro";
import { createClient } from "@supabase/supabase-js";
import { createServerClient, getUserFromCookies } from "../lib/supabaseServer";
import { PRICE_PER_CARTON } from "../lib/orderPricing";

export const prerender = false;

const user = await getUserFromCookies(Astro.cookies);
if (!user) {
	return Astro.redirect("/login");
}

const supabase = createServerClient();

const { data: preorderData } = await supabase
	.from("preorders")
	.select("id, name, start_date, end_date, status")
	.eq("status", "open")
	.limit(1)
	.maybeSingle();

const { data: flavorsData } = await supabase
	.from("flavors")
	.select("id, name, image_url, is_active")
	.eq("is_active", true)
	.order("name", { ascending: true });

const preorder = preorderData ?? null;
const flavors = flavorsData ?? [];
const projectRef = new URL(import.meta.env.SUPABASE_URL).hostname.split(".")[0];
const SUPABASE_SERVICE_ROLE_KEY = import.meta.env.SUPABASE_SERVICE_ROLE_KEY;

let repeatOrderPrefill: {
	orderId: string;
	cartons: number;
	promoCode: string;
	flavors: { flavor_id: string; quantity: number }[];
} | null = null;

const repeatOrderId = Astro.url.searchParams.get("repeatOrder");
if (repeatOrderId && SUPABASE_SERVICE_ROLE_KEY) {
	const adminClient = createClient(import.meta.env.SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY);
	const { data: repeatOrder } = await adminClient
		.from("orders")
		.select("id, user_id, cartons, promo_code")
		.eq("id", repeatOrderId)
		.eq("user_id", user.id)
		.maybeSingle();

	if (repeatOrder) {
		const { data: repeatFlavors } = await adminClient
			.from("order_flavors")
			.select("flavor_id, quantity")
			.eq("order_id", repeatOrder.id);

		repeatOrderPrefill = {
			orderId: repeatOrder.id,
			cartons: Number(repeatOrder.cartons || 1),
			promoCode: String(repeatOrder.promo_code || ""),
			flavors: (repeatFlavors ?? []).map((item) => ({
				flavor_id: item.flavor_id,
				quantity: Number(item.quantity || 0)
			}))
		};
	}
}
---

<Layout>
	<main class="app-shell px-4 pb-32 pt-8 sm:px-6 lg:px-8">
		<div class="mx-auto flex max-w-5xl flex-col gap-6">
			<header class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between"><div><p class="eyebrow">Précommande</p><h1 class="mt-2 text-4xl font-black tracking-tight text-[#101820]">Nouvelle commande</h1><p class="mt-2 text-sm text-slate-600">Choisis les cartons, le paiement et les goûts à réserver.</p></div><a href="/catalogue" class="btn-secondary px-4 py-3 text-sm">Voir le catalogue</a></header>

			{!preorder && (
				<section class="panel rounded-[1.6rem] border-dashed p-6 text-center text-slate-600">
					<p class="font-semibold text-slate-900">Aucune précommande en cours</p>
					<p class="text-sm">Revenez plus tard ou abonnez-vous aux notifications.</p>
				</section>
			)}

			<form
				id="precommande-form"
				class="space-y-5"
				novalidate
				data-preorder-id={preorder?.id || ""}
				data-preorder-end={preorder?.end_date || ""}
				data-project-ref={projectRef}
				data-price-per-carton={PRICE_PER_CARTON}
			>
				<input type="hidden" name="preorder_id" value={preorder?.id || ""} />

				{repeatOrderPrefill && (
					<section class="rounded-[1.4rem] border border-[#28e08f]/40 bg-[#ecfff6] p-4 text-sm text-slate-700">
						<p class="font-semibold text-slate-900">Commande pre-remplie</p>
						<p class="mt-1">
							On a repris les cartons et les goûts de ta commande precedente pour te faire gagner du temps.
						</p>
					</section>
				)}

				<section class="panel rounded-[1.6rem] p-5">
					<p class="text-sm font-black text-[#101820]">Quantite de cartons</p>
					<p class="text-xs font-bold text-slate-500">Prix unitaire : {PRICE_PER_CARTON} EUR</p>
					<div class="mt-4 flex items-center justify-center gap-4">
						<button type="button" data-action="decrease" class="flex h-12 w-12 items-center justify-center rounded-full bg-white text-2xl font-black text-[#101820] shadow-sm transition hover:-translate-y-0.5">
							-
						</button>
						<div class="text-center">
							<p class="text-2xl font-semibold text-slate-900" data-cartons>1</p>
							<p class="text-xs font-bold text-slate-500">carton</p>
						</div>
						<button type="button" data-action="increase" class="flex h-12 w-12 items-center justify-center rounded-full bg-[#28e08f] text-2xl font-black text-[#101820] shadow-sm transition hover:-translate-y-0.5">
							+
						</button>
					</div>
				</section>

				<section class="panel rounded-[1.6rem] p-5">
					<p class="text-sm font-black text-[#101820]">Recapitulatif</p>
					<div class="mt-4 space-y-2 text-sm text-slate-700">
						<div class="flex justify-between">
							<span>Sous-total</span>
							<span data-subtotal>{PRICE_PER_CARTON} EUR</span>
						</div>
						<div class="hidden justify-between" data-promo-row>
							<span data-promo-label>Code promo</span>
							<span data-promo-amount>-0 EUR</span>
						</div>
						<div class="flex justify-between text-base font-semibold text-slate-900">
							<span>Total</span>
							<span data-total>{PRICE_PER_CARTON} EUR</span>
						</div>
					</div>
				</section>

				<section class="panel rounded-[1.6rem] p-5">
					<div class="flex items-center justify-between gap-3">
						<div>
							<p class="text-sm font-black text-[#101820]">Code promo</p>
							<p class="text-xs font-bold text-slate-500">Ajoute une remise supplementaire si un code est actif.</p>
						</div>
					</div>
					<div class="mt-4 flex flex-col gap-3 sm:flex-row">
						<input
							type="text"
							id="promo-code-input"
							placeholder="Ex: BIENVENUE5"
							class="field text-sm font-black uppercase tracking-[0.15em]"
						/>
						<button
							type="button"
							id="apply-promo-btn"
							class="btn-secondary px-4 py-3 text-sm"
						>
							Appliquer
						</button>
					</div>
					<p class="mt-3 text-xs font-bold text-slate-500" id="promo-feedback"></p>
				</section>

				<section class="panel rounded-[1.6rem] p-5">
					<p class="text-sm font-black text-[#101820]">Mode de paiement</p>
					<div class="mt-4 space-y-3">
						<label class="block rounded-2xl border border-black/10 bg-white/70 px-4 py-3 text-sm font-bold text-[#101820] shadow-sm transition focus-within:border-[#28e08f] focus-within:ring-4 focus-within:ring-[#28e08f]/15">
							<div class="flex items-center gap-3">
								<input type="radio" name="payment_method" value="virement" class="accent-[#2d7dff]" />
								<div>
									<p>Virement bancaire</p>
									<p class="text-xs font-normal text-slate-500">Paiement sécurisé</p>
								</div>
							</div>
						</label>
						<label class="block rounded-2xl border border-black/10 bg-white/70 px-4 py-3 text-sm font-bold text-[#101820] shadow-sm transition focus-within:border-[#28e08f] focus-within:ring-4 focus-within:ring-[#28e08f]/15">
							<div class="flex items-center gap-3">
								<input type="radio" name="payment_method" value="liquide" class="accent-[#2d7dff]" />
								<div>
									<p>Paiement liquide</p>
									<p class="text-xs font-normal text-slate-500">À voir ensemble</p>
								</div>
							</div>
						</label>
					</div>
					<div id="iban-info" class="mt-4 hidden rounded-xl border border-blue-100 bg-blue-50 px-4 py-3 text-sm text-slate-700">
						<p class="font-semibold text-slate-900">Virement bancaire</p>
						<p>Titulaire: Noah ROGNON</p>
						<p>IBAN: FR76 2823 3000 0114 0003 6014 026</p>
					</div>
				</section>

				<section class="panel hidden rounded-[1.6rem] p-5" id="payment-proof-section">
					<div class="flex flex-col gap-2">
						<p class="text-sm font-black text-[#101820]">Preuve de paiement</p>
						<p class="text-xs font-bold text-slate-500">
							Ajoute une capture du virement bancaire. Sans preuve, la commande ne pourra pas être validée.
						</p>
					</div>
					<label class="mt-4 block cursor-pointer rounded-2xl border border-dashed border-black/20 bg-white/70 px-4 py-5 text-center transition hover:border-[#28e08f] hover:bg-white">
						<input
							type="file"
							id="payment-proof-input"
							accept="image/png,image/jpeg,image/webp"
							class="sr-only"
						/>
						<span class="block text-sm font-black text-[#101820]">Importer la preuve</span>
						<span class="mt-1 block text-xs font-bold text-slate-500">JPG, PNG ou WEBP - 6 Mo max</span>
					</label>
					<p class="mt-3 text-xs font-bold text-slate-500" id="payment-proof-feedback">
						Aucun fichier ajouté.
					</p>
					<div id="payment-proof-preview" class="mt-4 hidden overflow-hidden rounded-2xl border border-black/10 bg-white">
						<img
							id="payment-proof-preview-img"
							src=""
							alt="Aperçu de la preuve de paiement"
							class="max-h-80 w-full object-contain"
						/>
					</div>
				</section>

				<section class="panel rounded-[1.6rem] p-5">
					<div class="flex items-center justify-between">
						<div>
							<p class="text-sm font-black text-[#101820]">Sondage des goûts</p>
							<p class="text-xs font-bold text-slate-500">sélectionnéz vos goûts preferes</p>
						</div>
						<a
							href="/catalogue"
							class="btn-primary px-3 py-2 text-xs"
						>
							Voir le catalogue
						</a>
					</div>

					<div class="mt-4 space-y-3">
						{flavors.map((flavor) => (
							<div class="flex items-center justify-between rounded-xl border border-slate-200 bg-white px-3 py-3 shadow-sm">
								<div class="flex items-center gap-3">
									<img src={flavor.image_url || "/placeholder.jpg"} alt={flavor.name} class="h-10 w-10 rounded-lg object-cover" loading="lazy" />
									<span class="text-sm font-semibold text-slate-800">{flavor.name}</span>
								</div>
								<div class="flex items-center gap-2">
									<button type="button" class="flex h-8 w-8 items-center justify-center rounded-full bg-slate-100 text-lg font-semibold text-slate-600" data-flavor-decrease={flavor.id}>
										-
									</button>
									<span class="w-6 text-center text-sm font-black text-[#101820]" data-flavor-qty={flavor.id}>0</span>
									<button type="button" class="flex h-8 w-8 items-center justify-center rounded-full bg-amber-200 text-lg font-semibold text-amber-800" data-flavor-increase={flavor.id}>
										+
									</button>
								</div>
							</div>
						))}
					</div>
				</section>

				<div class="space-y-2" id="form-messages"></div>

				<button
					type="button"
					id="submit-precommande"
					class="btn-primary w-full px-4 py-3 text-sm disabled:cursor-not-allowed disabled:opacity-60"
					disabled={!preorder}
				>
					Valider la précommande
				</button>
			</form>
		</div>
	</main>

	<script type="application/json" id="repeat-order-data">
		{JSON.stringify(repeatOrderPrefill)}
	</script>

	<script type="module">
		(() => {
			console.log("SCRIPT CLIENT OK");
			const messagesEl = document.getElementById("form-messages");
			const submitBtn = document.getElementById("submit-precommande");
			const form = document.getElementById("precommande-form");
			if (!messagesEl || !submitBtn || !form) {
				console.error("précommande: elements introuvables");
				return;
			}

			const preorderId = form.getAttribute("data-preorder-id") || "";
			const preorderEnd = form.getAttribute("data-preorder-end") || "";
			const projectRef = form.getAttribute("data-project-ref") || "";
			const repeatOrderDataEl = document.getElementById("repeat-order-data");

			const pricePerCarton = Number(
				form.getAttribute("data-price-per-carton") || 0,
			);
			let cartons = 1;
			let appliedPromo = null;
			const flavorQuantities = new Map();
			form.querySelectorAll("[data-flavor-qty]").forEach((el) => {
				const id = el.getAttribute("data-flavor-qty");
				if (id) flavorQuantities.set(id, 0);
			});
			const ibanInfo = document.getElementById("iban-info");

			const cartEl = form.querySelector("[data-cartons]");
			const subtotalEl = form.querySelector("[data-subtotal]");
			const totalEl = form.querySelector("[data-total]");
			const promoRowEl = form.querySelector("[data-promo-row]");
			const promoLabelEl = form.querySelector("[data-promo-label]");
			const promoAmountEl = form.querySelector("[data-promo-amount]");
			const promoInput = document.getElementById("promo-code-input");
			const applyPromoBtn = document.getElementById("apply-promo-btn");
			const promoFeedback = document.getElementById("promo-feedback");
			const paymentProofInput = document.getElementById("payment-proof-input");
			const paymentProofFeedback = document.getElementById("payment-proof-feedback");
			const paymentProofSection = document.getElementById("payment-proof-section");
			const paymentProofPreview = document.getElementById("payment-proof-preview");
			const paymentProofPreviewImg = document.getElementById("payment-proof-preview-img");
			let paymentProofPreviewUrl = "";

			const syncPaymentProofVisibility = () => {
				const selectedMethod = form.querySelector("input[name='payment_method']:checked")?.value || "";
				const needsProof = selectedMethod === "virement";
				if (paymentProofSection) paymentProofSection.classList.toggle("hidden", !needsProof);
				if (!needsProof && paymentProofInput) {
					paymentProofInput.value = "";
					if (paymentProofFeedback) paymentProofFeedback.textContent = "Aucun fichier ajouté.";
					if (paymentProofPreviewUrl) URL.revokeObjectURL(paymentProofPreviewUrl);
					paymentProofPreviewUrl = "";
					if (paymentProofPreviewImg) paymentProofPreviewImg.removeAttribute("src");
					if (paymentProofPreview) paymentProofPreview.classList.add("hidden");
				}
			};

			if (paymentProofInput && paymentProofFeedback) {
				paymentProofInput.addEventListener("change", () => {
					const file = paymentProofInput.files?.[0];
					paymentProofFeedback.textContent = file
						? `${file.name} prêt à être envoyé.`
						: "Aucun fichier ajouté.";
					if (paymentProofPreviewUrl) URL.revokeObjectURL(paymentProofPreviewUrl);
					paymentProofPreviewUrl = "";
					if (!file) {
						if (paymentProofPreviewImg) paymentProofPreviewImg.removeAttribute("src");
						if (paymentProofPreview) paymentProofPreview.classList.add("hidden");
						return;
					}
					paymentProofPreviewUrl = URL.createObjectURL(file);
					if (paymentProofPreviewImg) paymentProofPreviewImg.src = paymentProofPreviewUrl;
					if (paymentProofPreview) paymentProofPreview.classList.remove("hidden");
				});
			}

			if (repeatOrderDataEl?.textContent) {
				try {
					const parsed = JSON.parse(repeatOrderDataEl.textContent);
					if (parsed && typeof parsed === "object") {
						cartons = Math.max(1, Number(parsed.cartons || 1));
						if (promoInput && parsed.promoCode) {
							promoInput.value = String(parsed.promoCode);
						}
						if (Array.isArray(parsed.flavors)) {
							parsed.flavors.forEach((item) => {
								if (!item?.flavor_id) return;
								const quantity = Math.max(0, Number(item.quantity || 0));
								flavorQuantities.set(item.flavor_id, quantity);
								const qtyEl = form.querySelector(`[data-flavor-qty='${item.flavor_id}']`);
								if (qtyEl) qtyEl.textContent = String(quantity);
							});
						}
					}
				} catch (error) {
					console.warn("Impossible de lire la commande a recommander", error);
				}
			}

			const renderTotals = () => {
				const subtotal = cartons * pricePerCarton;
				const baseTotal = subtotal;
				let promoAmount = 0;
				if (appliedPromo) {
					if (cartons < Number(appliedPromo.min_cartons || 1)) {
						appliedPromo = null;
						if (promoFeedback) {
							promoFeedback.textContent = "Le code promo a ete retire car la quantite minimale n'est plus atteinte.";
						}
					} else if (appliedPromo.type === "percent") {
						promoAmount = baseTotal * (Number(appliedPromo.value || 0) / 100);
					} else if (appliedPromo.type === "fixed") {
						promoAmount = Number(appliedPromo.value || 0);
					}
				}
				promoAmount = Math.max(0, Math.min(baseTotal, promoAmount));
				const total = Math.max(0, Math.round(baseTotal - promoAmount));

				if (cartEl) cartEl.textContent = String(cartons);
				if (subtotalEl) subtotalEl.textContent = `${subtotal} EUR`;
				if (totalEl) totalEl.textContent = `${total} EUR`;
				if (promoRowEl) {
					promoRowEl.classList.toggle("hidden", !appliedPromo);
					promoRowEl.classList.toggle("flex", Boolean(appliedPromo));
				}
				if (promoLabelEl) {
					promoLabelEl.textContent = appliedPromo ? `Code ${appliedPromo.code}` : "Code promo";
				}
				if (promoAmountEl) {
					promoAmountEl.textContent = `-${Math.round(promoAmount)} EUR`;
				}
				return { subtotal, promoAmount: Math.round(promoAmount), total };
			};

			const setMessage = (text, type = "error") => {
				messagesEl.innerHTML = "";
				if (!text) return;
				const p = document.createElement("p");
				p.className =
					type === "error"
						? "rounded-xl bg-red-50 px-4 py-3 text-sm text-red-700"
						: "rounded-xl bg-emerald-50 px-4 py-3 text-sm text-emerald-700";
				p.textContent = text;
				messagesEl.appendChild(p);
			};

			if (!preorderId) submitBtn.disabled = true;

			const totalFlavorCount = () => {
				let total = 0;
				for (const qty of flavorQuantities.values()) total += qty;
				return total;
			};

			form.addEventListener("change", (event) => {
				const target = event.target;
				if (!(target instanceof HTMLInputElement)) return;
				if (target.name === "payment_method" && ibanInfo) {
					if (target.value === "virement") {
						ibanInfo.classList.remove("hidden");
					} else {
						ibanInfo.classList.add("hidden");
					}
				}
				if (target.name === "payment_method") syncPaymentProofVisibility();
			});

			form.addEventListener("click", (event) => {
				const target = event.target;
				if (!(target instanceof HTMLElement)) return;
				const incCart = target.closest("[data-action='increase']");
				const decCart = target.closest("[data-action='decrease']");
				const incFlavor = target.closest("[data-flavor-increase]");
				const decFlavor = target.closest("[data-flavor-decrease]");

				if (incCart) {
					cartons += 1;
					renderTotals();
				}
				if (decCart) {
					if (cartons > 1) cartons -= 1;
					renderTotals();
				}
				if (incFlavor) {
					const id = incFlavor.getAttribute("data-flavor-increase");
					if (!id) return;
					if (totalFlavorCount() >= 10) {
						setMessage("Maximum 10 goûts sélectionnés.");
						return;
					}
					const next = (flavorQuantities.get(id) || 0) + 1;
					flavorQuantities.set(id, next);
					const qtyEl = form.querySelector(`[data-flavor-qty='${id}']`);
					if (qtyEl) qtyEl.textContent = String(next);
				}
				if (decFlavor) {
					const id = decFlavor.getAttribute("data-flavor-decrease");
					if (!id) return;
					const next = Math.max(0, (flavorQuantities.get(id) || 0) - 1);
					flavorQuantities.set(id, next);
					const qtyEl = form.querySelector(`[data-flavor-qty='${id}']`);
					if (qtyEl) qtyEl.textContent = String(next);
				}
			});

			renderTotals();
			const paymentSelected = form.querySelector("input[name='payment_method']:checked");
			if (paymentSelected && ibanInfo) {
				if (paymentSelected.value === "virement") {
					ibanInfo.classList.remove("hidden");
				}
			}
			syncPaymentProofVisibility();

			const addDays = (dateStr, days) => {
				const d = new Date(dateStr);
				d.setUTCDate(d.getUTCDate() + days);
				return d.toISOString();
			};

			if (applyPromoBtn && promoInput) {
				applyPromoBtn.addEventListener("click", async () => {
					const code = promoInput.value.trim().toUpperCase();
					if (!code) {
						appliedPromo = null;
						if (promoFeedback) promoFeedback.textContent = "Entre un code promo pour l'appliquer.";
						renderTotals();
						return;
					}

					applyPromoBtn.setAttribute("disabled", "true");
					applyPromoBtn.textContent = "Verification...";
					if (promoFeedback) promoFeedback.textContent = "";
					try {
						const response = await fetch("/api/validate-promo-code", {
							method: "POST",
							headers: { "Content-Type": "application/json" },
							body: JSON.stringify({ code, cartons })
						});
						const result = await response.json().catch(() => null);
						if (!response.ok || !result?.success) {
							appliedPromo = null;
							if (promoFeedback) {
								promoFeedback.textContent = result?.error || "Code promo invalide.";
							}
							renderTotals();
							return;
						}
						appliedPromo = {
							code: result.code,
							type: result.type,
							value: Number(result.value || 0),
							min_cartons: Number(result.min_cartons || 1)
						};
						if (promoFeedback) {
							promoFeedback.textContent = `Code ${result.code} applique avec succes.`;
						}
						renderTotals();
					} catch (error) {
						appliedPromo = null;
						if (promoFeedback) promoFeedback.textContent = "Impossible de verifier le code promo.";
						console.error(error);
					} finally {
						applyPromoBtn.removeAttribute("disabled");
						applyPromoBtn.textContent = "Appliquer";
					}
				});

				if (promoInput.value.trim()) {
					applyPromoBtn.click();
				}
			}

			submitBtn.addEventListener("click", async () => {
				setMessage("");
				submitBtn.disabled = true;

				if (!preorderId) {
					setMessage("Aucune précommande ouverte.");
					submitBtn.disabled = false;
					return;
				}

				const paymentMethod = form.querySelector("input[name='payment_method']:checked")?.value;
				const selectedFlavors = Array.from(flavorQuantities.entries())
					.filter(([_, qty]) => qty > 0)
					.map(([flavor_id, quantity]) => ({ flavor_id, quantity }));
				const selectedTotal = totalFlavorCount();

				if (cartons < 1) {
					setMessage("Veuillez sélectionnér au moins 1 carton.");
					submitBtn.disabled = false;
					return;
				}

				if (!paymentMethod) {
					setMessage("Veuillez choisir un mode de paiement.");
					submitBtn.disabled = false;
					return;
				}

				const paymentProofFile = paymentProofInput?.files?.[0] || null;
				if (paymentMethod === "virement" && !paymentProofFile) {
					setMessage("Ajoute une preuve de paiement avant de valider.");
					submitBtn.disabled = false;
					return;
				}

				if (selectedFlavors.length === 0) {
					setMessage("Veuillez sélectionnér au moins un goût.");
					submitBtn.disabled = false;
					return;
				}
				if (selectedTotal > 10) {
					setMessage("Maximum 10 goûts sélectionnés.");
					submitBtn.disabled = false;
					return;
				}

				const { total } = renderTotals();
				const estimated_delivery_start = addDays(preorderEnd, 14);
				const estimated_delivery_end = addDays(preorderEnd, 17);

				let authToken = "";
				if (projectRef && typeof window !== "undefined") {
					const key = `sb-${projectRef}-auth-token`;
					try {
						const stored = window.localStorage.getItem(key);
						if (stored) {
							const parsedToken = JSON.parse(stored);
							authToken = parsedToken?.access_token || "";
						}
					} catch (e) {
						console.warn("Impossible de lire le token Supabase", e);
					}
				}

				let paymentProofPath = "";
				if (paymentMethod === "virement") {
					try {
						submitBtn.textContent = "Envoi de la preuve...";
						if (paymentProofFeedback) paymentProofFeedback.textContent = "Upload de la preuve en cours...";
						const proofFormData = new FormData();
						proofFormData.append("proof", paymentProofFile);
						const proofResponse = await fetch("/api/upload-payment-proof", {
							method: "POST",
							headers: {
								...(authToken ? { Authorization: `Bearer ${authToken}` } : {})
							},
							body: proofFormData
						});
						const proofResult = await proofResponse.json().catch(() => null);
						if (!proofResponse.ok || !proofResult?.success || !proofResult?.path) {
							throw new Error(proofResult?.error || "Upload impossible.");
						}
						paymentProofPath = proofResult.path;
						if (paymentProofFeedback) paymentProofFeedback.textContent = "Preuve envoyée.";
					} catch (error) {
						console.error(error);
						setMessage(error?.message || "Impossible d'envoyer la preuve de paiement.");
						submitBtn.textContent = "Valider la précommande";
						submitBtn.disabled = false;
						return;
					}
				}

				submitBtn.textContent = "Création de la commande...";

				const response = await fetch("/api/create-order", {
					method: "POST",
					headers: {
						"Content-Type": "application/json",
						...(authToken ? { Authorization: `Bearer ${authToken}` } : {})
					},
					body: JSON.stringify({
						cartons,
						payment_method: paymentMethod,
						flavors: selectedFlavors,
						preorder_id: preorderId,
						estimated_delivery_start,
						estimated_delivery_end,
						total,
						promo_code: appliedPromo?.code || "",
						payment_proof_path: paymentProofPath
					})
				});

				let result = null;
				try {
					result = await response.json();
				} catch {
					result = null;
				}

				if (!response.ok || !result?.success) {
					setMessage(result?.error || "Impossible de creer la commande.");
					submitBtn.textContent = "Valider la précommande";
					submitBtn.disabled = false;
					return;
				}

				setMessage("Commande creee avec succes !", "success");
				window.location.href = "/dashboard";
			});
		})();
	</script>
</Layout>


