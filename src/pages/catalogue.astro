---
import Layout from "../layouts/Layout.astro";
import { createServerClient } from "../lib/supabaseServer";

export const prerender = false;

const supabase = createServerClient();
const { data, error } = await supabase
	.from("flavors")
	.select("id, name, description, image_url, is_active")
	.eq("is_active", true)
	.order("name", { ascending: true });

const flavors = data ?? [];
---

<Layout>
	<main class="app-shell px-4 py-10 sm:px-6 lg:px-8">
		<div class="mx-auto flex max-w-6xl flex-col gap-8">
			<header class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
				<div class="max-w-2xl">
					<p class="eyebrow">Catalogue</p>
					<h1 class="mt-2 text-4xl font-black tracking-tight text-[#101820] sm:text-5xl">Les goûts disponibles.</h1>
					<p class="mt-3 text-sm leading-6 text-slate-600 sm:text-base">Parcours les saveurs actives, repère tes favoris, puis lance ta précommande.</p>
				</div>
				<div class="flex flex-wrap gap-3">
					<a href="/precommande" class="btn-primary px-5 py-3 text-sm">Passer une précommande</a>
					<a href="/register" class="btn-secondary px-5 py-3 text-sm">Créer un compte</a>
				</div>
			</header>

			{error && <p class="rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm font-bold text-red-700">Une erreur est survenue lors du chargement du catalogue. {error.message}</p>}

			<section class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
				{flavors.length === 0 && (
					<div class="panel col-span-full rounded-[1.5rem] px-4 py-8 text-center text-sm font-bold text-slate-600">Aucun goût actif pour le moment.</div>
				)}

				{flavors.map((flavor) => (
					<article class="panel interactive group overflow-hidden rounded-[1.6rem] p-3">
						<div class="relative overflow-hidden rounded-[1.2rem] bg-white aspect-[4/3]">
							<img src={flavor.image_url || "/placeholder.jpg"} alt={flavor.name} class="h-full w-full object-contain p-4 transition duration-500 group-hover:scale-105" loading="lazy" />
							<span class="absolute left-3 top-3 rounded-full bg-[#28e08f] px-3 py-1 text-[0.65rem] font-black uppercase tracking-[0.12em] text-[#101820]">Actif</span>
						</div>
						<div class="p-2 pt-4">
							<h2 class="text-xl font-black text-[#101820]">{flavor.name}</h2>
							<p class="mt-2 min-h-10 text-sm leading-5 text-slate-600 line-clamp-2">{flavor.description || "Goût disponible dans la prochaine précommande."}</p>
							<div class="mt-4 flex gap-2">
								<a href="/precommande" class="btn-primary px-4 py-2 text-xs">Commander</a>
								<a href="/dashboard" class="btn-secondary px-4 py-2 text-xs">Mes commandes</a>
							</div>
						</div>
					</article>
				))}
			</section>
		</div>
	</main>
</Layout>
