---
import Layout from "../layouts/Layout.astro";
import { createClient } from "@supabase/supabase-js";
import { getUserFromCookies } from "../lib/supabaseServer";
import PreorderBanner from "../components/PreorderBanner.astro";
import DashboardNav from "../components/DashboardNav.astro";

export const prerender = false;

let firstName = "Invité";
let unreadNotifications = 0;
let latestNotifications: { id: string; title: string; message: string; link: string | null; is_read: boolean; created_at: string }[] = [];

const user = await getUserFromCookies(Astro.cookies);
const SUPABASE_SERVICE_ROLE_KEY = import.meta.env.SUPABASE_SERVICE_ROLE_KEY;

if (user) {
	const meta = user.user_metadata || {};
	if (typeof meta.first_name === "string" && meta.first_name.trim().length > 0) firstName = meta.first_name.trim();
	else if (typeof meta.firstName === "string" && meta.firstName.trim().length > 0) firstName = meta.firstName.trim();
	else if (typeof user.email === "string") firstName = user.email.split("@")[0] || firstName;

	if (SUPABASE_SERVICE_ROLE_KEY) {
		const adminClient = createClient(import.meta.env.SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY);
		const [{ data: notificationsData }, { count }] = await Promise.all([
			adminClient.from("notifications").select("id, title, message, link, is_read, created_at").eq("user_id", user.id).order("created_at", { ascending: false }).limit(3),
			adminClient.from("notifications").select("id", { count: "exact", head: true }).eq("user_id", user.id).eq("is_read", false)
		]);
		latestNotifications = notificationsData ?? [];
		unreadNotifications = count || 0;
	}
}
---

<Layout>
	<main class="app-shell px-4 pb-32 pt-8 sm:px-6 lg:px-8">
		<div class="mx-auto flex max-w-6xl flex-col gap-6">
			<section class="grid gap-5 lg:grid-cols-[1.2fr_0.8fr]">
				<div class="panel rounded-[2rem] p-6 sm:p-8">
					<p class="eyebrow">Espace membre</p>
					<h1 class="mt-3 text-4xl font-black leading-none tracking-tight text-[#101820] sm:text-5xl">
						Bonjour, <span class="text-[#116b4c]">{firstName}</span>
					</h1>
					<p class="mt-4 max-w-2xl text-sm leading-6 text-slate-600 sm:text-base">
						Ton espace centralise les précommandes ouvertes, les notifications et les actions rapides.
					</p>
					<div class="mt-6 flex flex-wrap gap-3">
						<a href="/precommande" class="btn-primary px-5 py-3 text-sm">Passer une commande</a>
						<a href="/profile" class="btn-secondary px-5 py-3 text-sm">Voir mes commandes</a>
					</div>
				</div>
				<div class="rounded-[2rem] bg-[#101820] p-6 text-white shadow-2xl shadow-slate-900/20">
					<p class="text-xs font-black uppercase tracking-[0.18em] text-[#28e08f]">À traiter</p>
					<p class="mt-4 text-5xl font-black">{unreadNotifications}</p>
					<p class="mt-2 text-sm font-bold text-white/55">notification(s) non lue(s)</p>
					<a href="/notifications" class="mt-6 inline-flex rounded-full bg-white px-4 py-2 text-sm font-black text-[#101820] transition hover:-translate-y-0.5">Ouvrir le centre</a>
				</div>
			</section>

			<PreorderBanner />

			<section class="grid gap-5 lg:grid-cols-2">
				<div class="panel rounded-[1.6rem] p-5">
					<div class="flex items-center justify-between gap-4">
						<div>
							<p class="text-lg font-black text-[#101820]">Notifications récentes</p>
							<p class="text-sm text-slate-600">{unreadNotifications > 0 ? `${unreadNotifications} à lire` : "Aucune alerte en attente"}</p>
						</div>
						<a href="/notifications" class="btn-secondary px-4 py-2 text-xs">Voir tout</a>
					</div>
					<div class="mt-4 space-y-3">
						{latestNotifications.length === 0 && <div class="rounded-2xl border border-dashed border-black/10 bg-white/60 px-4 py-4 text-sm font-bold text-slate-500">Tu recevras ici les infos sur tes commandes.</div>}
						{latestNotifications.map((notification) => (
							<a href={notification.link || "/notifications"} class={`block rounded-2xl border px-4 py-4 transition hover:-translate-y-0.5 ${notification.is_read ? "border-black/10 bg-white/55" : "border-[#28e08f]/50 bg-[#ecfff6]"}`}>
								<p class="text-sm font-black text-[#101820]">{notification.title}</p>
								<p class="mt-1 text-sm text-slate-600">{notification.message}</p>
							</a>
						))}
					</div>
				</div>

				<div class="panel rounded-[1.6rem] p-5">
					<p class="text-lg font-black text-[#101820]">Actions rapides</p>
					<p class="mt-1 text-sm text-slate-600">Les raccourcis qui servent vraiment.</p>
					<div class="mt-5 grid gap-3 sm:grid-cols-2">
						<a href="/catalogue" class="interactive rounded-2xl border border-black/10 bg-white/65 p-4">
							<p class="text-sm font-black text-[#101820]">Catalogue</p>
							<p class="mt-1 text-xs text-slate-500">Voir les goûts actifs</p>
						</a>
						<a href="/precommande" class="interactive rounded-2xl border border-black/10 bg-white/65 p-4">
							<p class="text-sm font-black text-[#101820]">Commander</p>
							<p class="mt-1 text-xs text-slate-500">Réserver maintenant</p>
						</a>
						<a href="/profile" class="interactive rounded-2xl border border-black/10 bg-white/65 p-4">
							<p class="text-sm font-black text-[#101820]">Historique</p>
							<p class="mt-1 text-xs text-slate-500">Recommander vite</p>
						</a>
						<a href="/notifications" class="interactive rounded-2xl border border-black/10 bg-white/65 p-4">
							<p class="text-sm font-black text-[#101820]">Alertes</p>
							<p class="mt-1 text-xs text-slate-500">Suivre les updates</p>
						</a>
					</div>
				</div>
			</section>
		</div>
	</main>
	<DashboardNav />
</Layout>
