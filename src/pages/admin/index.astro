						type="button"
						class="action-button action-primary"
						data-action="extend-preorder"
						disabled={!openPreorder}
					>
						Prolonger de 24h
					</button>
					<button
						type="button"
						class="action-button action-primary"
						data-action="send-supplier-email"
						data-preorder-id={openPreorder?.id || ""}
						disabled={!openPreorder}
					>
						Commande fournisseur envoyee
					</button>
					<button
						type="button"
						class="action-button action-success"
						data-action="send-stock-email"
						data-preorder-id={openPreorder?.id || ""}
						disabled={!openPreorder}
					>
						Stock recu / pret a livrer
					</button>
				</div>
				<p class="text-xs text-slate-500" data-admin-email-status></p>

				<div
					class="rounded-3xl bg-white/85 p-6 shadow-lg shadow-slate-200/60 ring-1 ring-white/50"
				>
					<div class="flex flex-col gap-2">
						<p class="text-sm font-semibold text-slate-900">
							Creer une precommande
						</p>
						<p class="text-xs text-slate-500">
							Nom, dates et statut initial pour lancer la prochaine
							fenetre.
						</p>
					</div>
					<form class="mt-6 grid gap-4 lg:grid-cols-2" data-preorder-form>
						<label class="space-y-2 text-sm text-slate-600 lg:col-span-2">
							<span class="font-medium text-slate-800">Nom</span>
							<input
								type="text"
								name="name"
								required
								class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 outline-none transition focus:border-[#7a4bff]"
								placeholder="Precommande Avril 2026"
							/>
						</label>
						<label class="space-y-2 text-sm text-slate-600">
							<span class="font-medium text-slate-800">
								Date de debut
							</span>
							<input
								type="datetime-local"
								name="start_date"
								required
								class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 outline-none transition focus:border-[#7a4bff]"
							/>
						</label>
						<label class="space-y-2 text-sm text-slate-600">
							<span class="font-medium text-slate-800">Date de fin</span>
							<input
								type="datetime-local"
								name="end_date"
								required
								class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 outline-none transition focus:border-[#7a4bff]"
							/>
						</label>
						<label class="space-y-2 text-sm text-slate-600">
							<span class="font-medium text-slate-800">
								Statut initial
							</span>
							<select
								name="status"
								class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 outline-none transition focus:border-[#7a4bff]"
							>
								<option value="planned">Planifiee</option>
								<option value="open">Ouverte</option>
								<option value="closed">Fermee</option>
							</select>
						</label>
						<div class="flex items-end">
							<button
								type="submit"
								class="action-button action-primary w-full justify-center"
							>
								Creer la precommande
							</button>
						</div>
					</form>
					<p class="mt-3 text-xs text-slate-500" data-preorder-form-status></p>
				</div>

				<div
					class="rounded-3xl bg-white/85 p-6 shadow-lg shadow-slate-200/60 ring-1 ring-white/50"
				>
					<div class="flex items-center justify-between">
						<div>
							<p class="text-sm font-semibold text-slate-900">
								Calendrier des precommandes
							</p>
							<p class="text-xs text-slate-500">
								Ouvrir, fermer ou prevoir les prochaines fenetres.
							</p>
						</div>
						<span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600">
							{formatNumber((preordersData ?? []).length)} fenetres
						</span>
					</div>
					<div class="mt-6 space-y-3">
						{(preordersData ?? []).map((preorder) => {
							const statusLabel =
								preorder.status === "open"
									? "Ouverte"
									: preorder.status === "planned"
										? "Planifiee"
										: "Fermee";
							const badgeClass =
								preorder.status === "open"
									? "badge-info"
									: preorder.status === "planned"
										? "badge-warning"
										: "badge-error";
							return (
								<div class="rounded-2xl border border-slate-100 bg-slate-50 px-4 py-4">
									<div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
										<div>
											<p class="text-sm font-semibold text-slate-800">
												{preorder.name}
											</p>
											<p class="text-xs text-slate-500">
												{formatDate(preorder.start_date)} au {formatDate(preorder.end_date)}
											</p>
										</div>
										<div class="flex flex-wrap items-center gap-2">
											<span class={`badge ${badgeClass}`}>{statusLabel}</span>
											{preorder.status !== "open" && (
												<button
													type="button"
													class="filter-button"
													data-action="set-preorder-status"
													data-preorder-id={preorder.id}
													data-next-status="open"
												>
													Ouvrir
												</button>
											)}
											{preorder.status !== "planned" && (
												<button
													type="button"
													class="filter-button"
													data-action="set-preorder-status"
													data-preorder-id={preorder.id}
													data-next-status="planned"
												>
													Planifier
												</button>
											)}
											{preorder.status !== "closed" && (
												<button
													type="button"
													class="filter-button"
													data-action="set-preorder-status"
													data-preorder-id={preorder.id}
													data-next-status="closed"
												>
													Fermer
												</button>
											)}
										</div>
									</div>
								</div>
							);
						})}
						{(preordersData ?? []).length === 0 && (
							<p class="text-sm text-slate-500">
								Aucune precommande enregistree pour le moment.
							</p>
						)}
					</div>
				</div>

				<div
					class="rounded-3xl bg-white/85 p-6 shadow-lg shadow-slate-200/60 ring-1 ring-white/50"
				>
					<div class="flex items-center justify-between">
						<div>
							<p class="text-sm font-semibold text-slate-900">
								Calcul de l'arrivage
							</p>
							<p class="text-xs text-slate-500">
								Repartition des gouts demandes
							</p>
						</div>
					</div>
					<div class="mt-6 space-y-4">
						{
							openFlavorStats.map((item) => {
								const percent =
									openOrders.length > 0
										? (item.orders / openOrders.length) *
											100
										: 0;
								return (
									<div class="rounded-2xl border border-slate-100 bg-slate-50 px-4 py-3">
										<p class="text-sm font-semibold text-slate-800">
											{item.name}
										</p>
										<div class="mt-1 flex items-center gap-3 text-xs text-slate-500">
											<span>{item.quantity} cartons</span>
											<span>
												Demande par {percent.toFixed(0)}
												% des clients
											</span>
										</div>
									</div>
								);
							})
						}
						{
							openFlavorStats.length === 0 && (
								<p class="text-sm text-slate-500">
									Aucune demande pour cette precommande.
								</p>
							)
						}
					</div>
				</div>
			</section>
		</div>
	</main>
</Layout>

<script>
	const tabButtons = Array.from(
		document.querySelectorAll("[data-tab-target]"),
	);
	const tabPanels = Array.from(document.querySelectorAll("[data-tab-panel]"));
	const tabButtonClass = "tab-active";

	const activateTab = (target) => {
		tabButtons.forEach((button) => {
			const isActive = button.dataset.tabTarget === target;
			button.classList.toggle(tabButtonClass, isActive);
		});
		tabPanels.forEach((panel) => {
			panel.classList.toggle("hidden", panel.dataset.tabPanel !== target);
		});
	};

	tabButtons.forEach((button) => {
		button.addEventListener("click", () =>
			activateTab(button.dataset.tabTarget),
		);
	});

	const filterButtons = Array.from(
		document.querySelectorAll("[data-status-filter]"),
	);
	const searchInput = document.querySelector("[data-order-search]");
	const preorderFilter = document.querySelector("[data-preorder-filter]");
	const orderCards = Array.from(
		document.querySelectorAll("[data-order-card]"),
	);
	const emailStatus = document.querySelector("[data-admin-email-status]");
	const preorderForm = document.querySelector("[data-preorder-form]");
	const preorderFormStatus = document.querySelector(
		"[data-preorder-form-status]",
	);
	const promoForm = document.querySelector("[data-promo-form]");
	const promoFormStatus = document.querySelector("[data-promo-form-status]");
	let activeStatus = "all";
	let activePreorder =
		preorderFilter instanceof HTMLSelectElement
			? preorderFilter.value || "all"
			: "all";

	const applyFilters = () => {
		const query = (searchInput?.value || "").trim().toLowerCase();
		orderCards.forEach((card) => {
			const status = card.dataset.status || "";
			const search = card.dataset.search || "";
			const preorderId = card.dataset.preorderId || "";
			const statusMatch =
				activeStatus === "all" || status === activeStatus;
			const preorderMatch =
				activePreorder === "all" || preorderId === activePreorder;
			const queryMatch = !query || search.includes(query);
			card.classList.toggle(
				"hidden",
				!(statusMatch && preorderMatch && queryMatch),
			);
		});
	};

	filterButtons.forEach((button) => {
		button.addEventListener("click", () => {
			activeStatus = button.dataset.statusFilter || "all";
			filterButtons.forEach((btn) =>
				btn.classList.toggle("filter-active", btn === button),
			);
			applyFilters();
		});
	});

	if (searchInput) {
		searchInput.addEventListener("input", applyFilters);
	}

	if (preorderFilter instanceof HTMLSelectElement) {
		preorderFilter.addEventListener("change", () => {
			activePreorder = preorderFilter.value || "all";
			applyFilters();
		});
	}

	applyFilters();

	if (preorderForm instanceof HTMLFormElement) {
		preorderForm.addEventListener("submit", async (event) => {
			event.preventDefault();
			const formData = new FormData(preorderForm);
			const submitButton = preorderForm.querySelector(
				"button[type='submit']",
			);
			if (submitButton instanceof HTMLButtonElement) {
				submitButton.disabled = true;
				submitButton.textContent = "Creation...";
			}
			if (preorderFormStatus) {
				preorderFormStatus.textContent =
					"Creation de la precommande en cours...";
			}
			try {
				const response = await fetch("/api/admin/create-preorder", {
					method: "POST",
					headers: { "content-type": "application/json" },
					body: JSON.stringify({
						name: formData.get("name"),
						start_date: formData.get("start_date"),
						end_date: formData.get("end_date"),
						status: formData.get("status"),
					}),
				});
				const result = await response.json();
				if (!response.ok) {
					throw new Error(result?.error || result?.message || "Erreur");
				}
				if (preorderFormStatus) {
					preorderFormStatus.textContent =
						"Precommande creee. Rechargement...";
				}
				window.location.reload();
			} catch (error) {
				if (preorderFormStatus) {
					preorderFormStatus.textContent =
						"Impossible de creer la precommande.";
				}
				console.error(error);
				if (submitButton instanceof HTMLButtonElement) {
					submitButton.disabled = false;
					submitButton.textContent = "Creer la precommande";
				}
			}
		});
	}

	if (promoForm instanceof HTMLFormElement) {
		promoForm.addEventListener("submit", async (event) => {
			event.preventDefault();
			const formData = new FormData(promoForm);
			const submitButton = promoForm.querySelector("button[type='submit']");
			if (submitButton instanceof HTMLButtonElement) {
				submitButton.disabled = true;
				submitButton.textContent = "Creation...";
			}
			if (promoFormStatus) {
				promoFormStatus.textContent = "Creation du code promo en cours...";
			}
			try {
				const response = await fetch("/api/admin/create-promo-code", {
					method: "POST",
					headers: { "content-type": "application/json" },
					body: JSON.stringify({
						code: formData.get("code"),
						type: formData.get("type"),
						value: formData.get("value"),
						min_cartons: formData.get("min_cartons"),
						max_uses: formData.get("max_uses"),
						starts_at: formData.get("starts_at"),
						ends_at: formData.get("ends_at"),
						is_active: formData.get("is_active") === "on"
					})
				});
				const result = await response.json();
				if (!response.ok) {
					throw new Error(result?.error || "Erreur");
				}
				if (promoFormStatus) {
					promoFormStatus.textContent = `Code ${result?.promo?.code || ""} cree.`;
				}
				window.location.reload();
			} catch (error) {
				if (promoFormStatus) {
					promoFormStatus.textContent = "Impossible de creer le code promo.";
				}
				console.error(error);
				if (submitButton instanceof HTMLButtonElement) {
					submitButton.disabled = false;
					submitButton.textContent = "Ajouter le code promo";
				}
			}
		});
	}

	document.addEventListener("click", async (event) => {
		const target = event.target;
		if (!(target instanceof HTMLElement)) return;

		const toggleButton = target.closest("[data-action='toggle-order']");
		if (toggleButton) {
			const card = toggleButton.closest("[data-order-card]");
			const details = card?.querySelector("[data-order-details]");
			if (details) {
				details.classList.toggle("hidden");
				toggleButton.classList.toggle("rotate-180");
			}
			return;
		}

		const actionButton = target.closest("[data-action='update-status']");
		if (actionButton) {
			const orderId = actionButton.getAttribute("data-order-id");
			const nextStatus = actionButton.getAttribute("data-next-status");
			if (!orderId || !nextStatus) return;
			const originalText = actionButton.textContent || "";
			actionButton.setAttribute("disabled", "true");
			actionButton.textContent = "Mise a jour...";
			try {
				const response = await fetch("/api/admin/update-order-status", {
					method: "POST",
					headers: { "content-type": "application/json" },
					body: JSON.stringify({
						order_id: orderId,
						status: nextStatus,
					}),
				});
				if (!response.ok) {
					throw new Error(await response.text());
				}
				window.location.reload();
			} catch (err) {
				actionButton.removeAttribute("disabled");
				actionButton.textContent = originalText;
				console.error(err);
			}
			return;
		}

		const closeButton = target.closest("[data-action='close-preorder']");
		if (closeButton) {
			closeButton.setAttribute("disabled", "true");
			closeButton.textContent = "Cloture...";
			try {
				const response = await fetch("/api/admin/close-preorder", {
					method: "POST",
				});
				if (!response.ok) throw new Error(await response.text());
				window.location.reload();
			} catch (err) {
				closeButton.removeAttribute("disabled");
				closeButton.textContent = "Cloturer les precommandes";
				console.error(err);
			}
			return;
		}

		const extendButton = target.closest("[data-action='extend-preorder']");
		if (extendButton) {
			extendButton.setAttribute("disabled", "true");
			extendButton.textContent = "Prolongation...";
			try {
				const response = await fetch("/api/admin/extend-preorder", {
					method: "POST",
				});
				if (!response.ok) throw new Error(await response.text());
				window.location.reload();
			} catch (err) {
				extendButton.removeAttribute("disabled");
				extendButton.textContent = "Prolonger de 24h";
				console.error(err);
			}
		}

		const supplierButton = target.closest("[data-action='send-supplier-email']");
		if (supplierButton) {
			const preorderId = supplierButton.getAttribute("data-preorder-id") || "";
			if (!preorderId) return;
			supplierButton.setAttribute("disabled", "true");
			supplierButton.textContent = "Envoi...";
			if (emailStatus) emailStatus.textContent = "Envoi des emails fournisseur...";
			try {
				const response = await fetch("/api/admin/preorder/send-supplier-order-emails", {
					method: "POST",
					headers: { "content-type": "application/json" },
					body: JSON.stringify({ preorderId })
				});
				const result = await response.json();
				if (!response.ok) throw new Error(result?.error || "Erreur");
				if (emailStatus) emailStatus.textContent = `Emails envoyes: ${result?.sent ?? 0}`;
			} catch (err) {
				if (emailStatus) emailStatus.textContent = "Erreur lors de l'envoi des emails.";
				console.error(err);
			} finally {
				supplierButton.removeAttribute("disabled");
				supplierButton.textContent = "Commande fournisseur envoyee";
			}
			return;
		}

		const stockButton = target.closest("[data-action='send-stock-email']");
		if (stockButton) {
			const preorderId = stockButton.getAttribute("data-preorder-id") || "";
			if (!preorderId) return;
			stockButton.setAttribute("disabled", "true");
			stockButton.textContent = "Envoi...";
			if (emailStatus) emailStatus.textContent = "Envoi des emails stock recu...";
			try {
				const response = await fetch("/api/admin/preorder/send-stock-received-emails", {
					method: "POST",
					headers: { "content-type": "application/json" },
					body: JSON.stringify({ preorderId })
				});
				const result = await response.json();
				if (!response.ok) throw new Error(result?.error || "Erreur");
				if (emailStatus) emailStatus.textContent = `Emails envoyes: ${result?.sent ?? 0}`;
			} catch (err) {
				if (emailStatus) emailStatus.textContent = "Erreur lors de l'envoi des emails.";
				console.error(err);
			} finally {
				stockButton.removeAttribute("disabled");
				stockButton.textContent = "Stock recu / pret a livrer";
			}
		}

		const openEmailButton = target.closest("[data-action='send-open-email']");
		if (openEmailButton) {
			const preorderId =
				openEmailButton.getAttribute("data-preorder-id") || "";
			if (!preorderId) return;
			openEmailButton.setAttribute("disabled", "true");
			openEmailButton.textContent = "Envoi...";
			if (emailStatus) {
				emailStatus.textContent =
					"Envoi de l'annonce d'ouverture aux clients...";
			}
			try {
				const response = await fetch("/api/admin/preorder/send-open-emails", {
					method: "POST",
					headers: { "content-type": "application/json" },
					body: JSON.stringify({ preorderId }),
				});
				const result = await response.json();
				if (!response.ok) throw new Error(result?.error || "Erreur");
				if (emailStatus) {
					emailStatus.textContent = `Annonce envoyee a ${result?.sent ?? 0} clients.`;
				}
			} catch (error) {
				if (emailStatus) {
					emailStatus.textContent =
						"Erreur lors de l'envoi du mail d'ouverture.";
				}
				console.error(error);
			} finally {
				openEmailButton.removeAttribute("disabled");
				openEmailButton.textContent = "Annoncer l'ouverture par email";
			}
			return;
		}

		const preorderStatusButton = target.closest(
			"[data-action='set-preorder-status']",
		);
		if (preorderStatusButton) {
			const preorderId =
				preorderStatusButton.getAttribute("data-preorder-id") || "";
			const status =
				preorderStatusButton.getAttribute("data-next-status") || "";
			if (!preorderId || !status) return;
			preorderStatusButton.setAttribute("disabled", "true");
			const initialText = preorderStatusButton.textContent || "";
			preorderStatusButton.textContent = "Mise a jour...";
			try {
				const response = await fetch("/api/admin/update-preorder-status", {
					method: "POST",
					headers: { "content-type": "application/json" },
					body: JSON.stringify({ preorderId, status }),
				});
				if (!response.ok) {
					throw new Error(await response.text());
				}
				window.location.reload();
			} catch (error) {
				preorderStatusButton.removeAttribute("disabled");
				preorderStatusButton.textContent = initialText;
				console.error(error);
			}
			return;
		}

		const togglePromoButton = target.closest(
			"[data-action='toggle-promo-status']",
		);
		if (togglePromoButton) {
			const promoId = togglePromoButton.getAttribute("data-promo-id") || "";
			const isActive =
				togglePromoButton.getAttribute("data-promo-active") === "true";
			if (!promoId) return;
			togglePromoButton.setAttribute("disabled", "true");
			const initialText = togglePromoButton.textContent || "";
			togglePromoButton.textContent = "Mise a jour...";
			try {
				const response = await fetch("/api/admin/update-promo-code", {
					method: "POST",
					headers: { "content-type": "application/json" },
					body: JSON.stringify({
						promoId,
						is_active: !isActive
					})
				});
				if (!response.ok) {
					throw new Error(await response.text());
				}
				window.location.reload();
			} catch (error) {
				togglePromoButton.removeAttribute("disabled");
				togglePromoButton.textContent = initialText;
				console.error(error);
			}
			return;
		}
	});

	const countdownEl = document.querySelector("[data-countdown]");
	if (countdownEl) {
		const endDate = countdownEl.getAttribute("data-end-date");
		if (endDate) {
			const endTime = new Date(endDate).getTime();
			const valueEl = countdownEl.querySelector(".metric-value");
			const tick = () => {
				const diff = endTime - Date.now();
				if (!valueEl) return;
				if (diff <= 0) {
					valueEl.textContent = "Terminee";
					return;
				}
				const hours = Math.floor(diff / 3600000);
				const minutes = Math.floor((diff % 3600000) / 60000);
				valueEl.textContent = `${String(hours).padStart(2, "0")}h ${String(
					minutes,
				).padStart(2, "0")}m`;
			};
			tick();
			setInterval(tick, 1000);
		}
	}
</script>

<style>
	.tab-button {
		position: relative;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		border-radius: 999px;
