---
import Layout from "../layouts/Layout.astro";
import { createServerClient } from "../lib/supabaseServer";

export const prerender = false;

let error: string | null = null;
let success: string | null = null;
const SUPABASE_URL = import.meta.env.SUPABASE_URL as string;
const SUPABASE_ANON_KEY = import.meta.env.SUPABASE_ANON_KEY as string;

if (Astro.request.method === "POST") {
	const supabase = createServerClient();
	let email = "";
	let password = "";
	let authAction = "password";

	try {
		try {
			const formData = await Astro.request.formData();
			email = String(formData.get("email") || "").trim();
			password = String(formData.get("password") || "");
			authAction = String(formData.get("auth_action") || "password");
		} catch {
			const body = (await Astro.request.json()) as Record<string, unknown>;
			email = String(body.email || "").trim();
			password = String(body.password || "");
			authAction = String(body.auth_action || "password");
		}

		if (authAction === "magic") {
			if (!email) {
				error = "Entre ton email pour recevoir un lien magique.";
			} else {
				const { error: otpError } = await supabase.auth.signInWithOtp({
					email,
					options: {
						emailRedirectTo: `${Astro.url.origin}/auth/callback`,
						shouldCreateUser: false
					}
				});
				if (otpError) error = otpError.message;
				else success = "Si ce compte existe, un lien de connexion vient d'être envoyé.";
			}
		} else {
			const { data, error: signInError } = await supabase.auth.signInWithPassword({ email, password });

			if (signInError) {
				error = signInError.message;
			} else {
				if (data?.session) {
					const isSecure = Astro.url.protocol === "https:";
					Astro.cookies.set("sb-access-token", data.session.access_token, { path: "/", httpOnly: true, sameSite: "lax", secure: isSecure });
					Astro.cookies.set("sb-refresh-token", data.session.refresh_token, { path: "/", httpOnly: true, sameSite: "lax", secure: isSecure });
				}
				return Astro.redirect("/dashboard");
			}
		}
	} catch {
		error = "Le formulaire n'a pas pu être lu. Merci de réessayer.";
	}
}
---

<Layout>
	<main
		class="app-shell px-4 py-10 sm:px-6 lg:px-8"
		data-supabase-url={SUPABASE_URL}
		data-supabase-anon-key={SUPABASE_ANON_KEY}
	>
		<div class="mx-auto grid min-h-[72vh] max-w-5xl items-center gap-8 lg:grid-cols-[1fr_0.9fr]">
			<section class="hidden lg:block">
				<p class="eyebrow">Espace membre</p>
				<h1 class="mt-3 text-5xl font-black leading-none tracking-tight text-[#101820]">Bon retour dans ton espace commande.</h1>
				<p class="mt-5 max-w-xl text-base leading-7 text-slate-600">Connecte-toi avec ton mot de passe ou reçois un lien magique par email.</p>
			</section>

			<section class="panel rounded-[2rem] p-6 sm:p-8">
				<a href="/" class="mb-6 inline-flex text-sm font-bold text-slate-500 transition hover:text-[#101820]">← Retour</a>
				<div class="space-y-1">
					<p class="eyebrow">Connexion</p>
					<h2 class="text-3xl font-black tracking-tight text-[#101820]">Se connecter</h2>
					<p class="text-sm text-slate-600">Mot de passe, lien magique ou récupération de compte.</p>
				</div>

				{error && <p class="mt-4 rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm font-bold text-red-700">{error}</p>}
				{success && <p class="mt-4 rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-bold text-emerald-700">{success}</p>}

				<button
					type="button"
					class="mt-6 flex w-full items-center justify-center gap-3 rounded-full border border-black/10 bg-white px-4 py-3 text-sm font-black text-[#101820] shadow-sm transition hover:-translate-y-0.5 hover:border-[#101820]/30 hover:shadow-lg disabled:cursor-not-allowed disabled:opacity-70"
					data-google-login
				>
					<span class="flex h-6 w-6 items-center justify-center rounded-full bg-[#101820] text-xs font-black text-white">G</span>
					<span>Continuer avec Google</span>
				</button>

				<div class="my-5 flex items-center gap-3">
					<div class="h-px flex-1 bg-black/10"></div>
					<span class="text-xs font-black uppercase tracking-[0.16em] text-slate-400">ou</span>
					<div class="h-px flex-1 bg-black/10"></div>
				</div>

				<form method="POST" class="mt-6 space-y-4">
					<input type="hidden" name="auth_action" value="password" />
					<input type="email" name="email" placeholder="Email" class="field text-sm" required />
					<input type="password" name="password" placeholder="Mot de passe" class="field text-sm" required />
					<button type="submit" class="btn-primary mt-2 w-full px-4 py-3 text-sm">Se connecter</button>
				</form>

				<div class="mt-4 flex items-center justify-between gap-3 text-sm">
					<a href="/forgot-password" class="font-black text-[#116b4c] transition hover:text-[#101820]">Mot de passe oublié ?</a>
				</div>

				<div class="my-5 flex items-center gap-3">
					<div class="h-px flex-1 bg-black/10"></div>
					<span class="text-xs font-black uppercase tracking-[0.16em] text-slate-400">ou</span>
					<div class="h-px flex-1 bg-black/10"></div>
				</div>

				<form method="POST" class="space-y-3">
					<input type="hidden" name="auth_action" value="magic" />
					<input type="email" name="email" placeholder="Email pour lien magique" class="field text-sm" required />
					<button type="submit" class="btn-secondary w-full px-4 py-3 text-sm">Recevoir un lien magique</button>
				</form>

				<p class="mt-4 rounded-2xl bg-[#101820]/5 px-4 py-3 text-center text-xs font-bold text-slate-600">Je certifie avoir plus de 18 ans.</p>
				<p class="mt-5 text-center text-sm text-slate-600">
					Pas encore de compte ?
					<a href="/register" class="font-black text-[#116b4c] transition hover:text-[#101820]">Créer un compte</a>
				</p>
			</section>
		</div>
	</main>

	<script>
		import { createClient } from "@supabase/supabase-js";

		const root = document.querySelector("[data-supabase-url]");
		const googleButton = document.querySelector("[data-google-login]");

		if (root && googleButton instanceof HTMLButtonElement) {
			const supabase = createClient(root.dataset.supabaseUrl, root.dataset.supabaseAnonKey);

			googleButton.addEventListener("click", async () => {
				googleButton.disabled = true;
				const initialText = googleButton.innerHTML;
				googleButton.innerHTML = "<span>Redirection vers Google...</span>";

				const { error } = await supabase.auth.signInWithOAuth({
					provider: "google",
					options: {
						redirectTo: `${window.location.origin}/auth/callback`,
						queryParams: {
							access_type: "offline",
							prompt: "consent"
						}
					}
				});

				if (error) {
					console.error(error);
					googleButton.disabled = false;
					googleButton.innerHTML = initialText;
					alert("Connexion Google impossible pour le moment.");
				}
			});
		}
	</script>
</Layout>
