---
import Layout from "../layouts/Layout.astro";
import DashboardNav from "../components/DashboardNav.astro";
import { createClient } from "@supabase/supabase-js";
import { PRICE_PER_CARTON, SAVINGS_PER_CARTON } from "../lib/orderPricing";

export const prerender = false;

const SUPABASE_URL = import.meta.env.SUPABASE_URL;
const SUPABASE_SERVICE_ROLE_KEY = import.meta.env.SUPABASE_SERVICE_ROLE_KEY;

const token = Astro.cookies.get("sb-access-token")?.value || "";
if (!token) return Astro.redirect("/login");
if (!SUPABASE_SERVICE_ROLE_KEY) throw new Error("SUPABASE_SERVICE_ROLE_KEY manquant");

const adminClient = createClient(SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY);
const { data: userData, error: userError } = await adminClient.auth.getUser(token);
const user = userData?.user;
if (userError || !user) return Astro.redirect("/login");

const { data: ordersData } = await adminClient
	.from("orders")
	.select("id, order_number, cartons, total, status, estimated_delivery_start, estimated_delivery_end, payment_method, preorder_id, created_at, payment_proof_status, payment_proof_rejection_reason")
	.eq("user_id", user.id)
	.order("created_at", { ascending: false });

const orders = ordersData ?? [];
const orderIds = orders.map((o) => o.id);

const { data: openPreordersData } = await adminClient.from("preorders").select("id").eq("status", "open");
const openPreorders = new Set((openPreordersData ?? []).map((p) => p.id));

let flavorCounts: Record<string, number> = {};
const supplierSentOrders = new Set<string>();
const stockReceivedOrders = new Set<string>();
if (orderIds.length > 0) {
	const { data: orderFlavorsData } = await adminClient.from("order_flavors").select("order_id, quantity").in("order_id", orderIds);
	for (const row of orderFlavorsData ?? []) {
		const key = row.order_id as string;
		const qty = Number(row.quantity || 0);
		flavorCounts[key] = (flavorCounts[key] || 0) + qty;
	}

	const { data: emailLogsData } = await adminClient
		.from("email_logs")
		.select("order_id, type")
		.in("order_id", orderIds)
		.in("type", ["supplier_order_sent", "stock_received"]);
	for (const log of emailLogsData ?? []) {
		if (!log.order_id) continue;
		if (log.type === "supplier_order_sent") supplierSentOrders.add(log.order_id);
		if (log.type === "stock_received") stockReceivedOrders.add(log.order_id);
	}
}

const totalOrders = orders.length;
const totalCartons = orders.reduce((sum, o) => sum + Number(o.cartons || 0), 0);
const totalSpent = orders.reduce((sum, o) => sum + Number(o.total || 0), 0);
const totalSavings = totalCartons * SAVINGS_PER_CARTON;

const formatDate = (value: string | null) => {
	if (!value) return "";
	return new Date(value).toISOString().slice(0, 10);
};

const statusLabel = (status: string | null) => {
	if (status === "delivered") return { text: "Livrée", className: "bg-emerald-100 text-emerald-800" };
	if (status === "confirmed") return { text: "Confirmée", className: "bg-blue-100 text-blue-800" };
	return { text: "En cours", className: "bg-amber-100 text-amber-800" };
};

const orderTimeline = (order: any) => {
	const isDelivered = order.status === "delivered";
	const paymentValidated = order.status === "confirmed" || isDelivered || order.payment_proof_status === "valid";
	const paymentInvalid = order.payment_proof_status === "invalid";
	const supplierSent = supplierSentOrders.has(order.id);
	const stockReceived = stockReceivedOrders.has(order.id);
	return [
		{ label: "Commande creee", state: "done" },
		{
			label: paymentInvalid ? "Paiement a corriger" : "Paiement en attente",
			state: paymentValidated ? "done" : paymentInvalid ? "error" : "current"
		},
		{ label: "Paiement valide", state: paymentValidated ? "done" : "todo" },
		{ label: "Commande fournisseur envoyee", state: supplierSent ? "done" : paymentValidated ? "current" : "todo" },
		{ label: "Stock recu", state: stockReceived ? "done" : supplierSent ? "current" : "todo" },
		{ label: "Livree", state: isDelivered ? "done" : stockReceived ? "current" : "todo" }
	];
};

const timelineDotClass = (state: string) => {
	if (state === "done") return "bg-[#28e08f] text-[#101820] ring-[#28e08f]/25";
	if (state === "current") return "bg-[#101820] text-white ring-[#101820]/15";
	if (state === "error") return "bg-red-500 text-white ring-red-500/20";
	return "bg-slate-200 text-slate-500 ring-slate-200/30";
};

const timelineTextClass = (state: string) => {
	if (state === "error") return "text-red-700";
	if (state === "todo") return "text-slate-400";
	return "text-[#101820]";
};
---

<Layout>
	<main class="app-shell px-4 pb-32 pt-8 sm:px-6 lg:px-8" data-price-per-carton={PRICE_PER_CARTON}>
		<div class="mx-auto flex max-w-5xl flex-col gap-6">
			<header class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
				<div>
					<p class="eyebrow">Historique</p>
					<h1 class="mt-2 text-4xl font-black tracking-tight text-[#101820]">Mes commandes</h1>
					<p class="mt-2 text-sm text-slate-600">Suivi, édition et recommande rapide.</p>
				</div>
				<a href="/precommande" class="btn-primary px-5 py-3 text-sm">Nouvelle commande</a>
			</header>

			<section class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
				<div class="panel rounded-[1.4rem] p-5"><p class="text-3xl font-black text-[#101820]">{totalOrders}</p><p class="text-xs font-bold text-slate-500">Commandes</p></div>
				<div class="panel rounded-[1.4rem] p-5"><p class="text-3xl font-black text-[#101820]">{totalCartons}</p><p class="text-xs font-bold text-slate-500">Cartons</p></div>
				<div class="panel rounded-[1.4rem] p-5"><p class="text-3xl font-black text-[#101820]">{Math.round(totalSpent)}€</p><p class="text-xs font-bold text-slate-500">Dépensé</p></div>
				<div class="panel rounded-[1.4rem] p-5"><p class="text-3xl font-black text-[#101820]">{Math.round(totalSavings)}€</p><p class="text-xs font-bold text-slate-500">Économies estimées</p></div>
			</section>

			<section class="rounded-[1.5rem] bg-[#101820] p-5 text-white">
				<p class="text-sm font-black text-[#28e08f]">Virement bancaire</p>
				<p class="mt-2 text-sm text-white/75">Noah ROGNON</p>
				<p class="text-sm text-white/75">IBAN: FR76 2823 3000 0114 0003 6014 026</p>
			</section>

			<section class="space-y-4">
				{orders.length === 0 && <div class="panel rounded-[1.5rem] p-6 text-center text-sm font-bold text-slate-600">Aucune commande pour le moment.</div>}

				{orders.map((order) => {
					const status = statusLabel(order.status);
					const canEdit = openPreorders.has(order.preorder_id);
					const orderFlavors = flavorCounts[order.id] || 0;
					return (
						<article class="panel interactive rounded-[1.6rem] p-5">
							<div class="flex items-start justify-between gap-4">
								<div>
									<p class="text-lg font-black text-[#101820]">{order.order_number || "CMD-XXXX"}</p>
									<p class="text-xs font-bold text-slate-400">{formatDate(order.created_at)}</p>
								</div>
								<span class={`rounded-full px-3 py-1 text-xs font-black ${status.className}`}>{status.text}</span>
							</div>

							<div class="mt-5 grid grid-cols-3 gap-2 text-center">
								<div class="rounded-2xl bg-white/60 p-3"><p class="text-xl font-black text-[#101820]">{order.cartons}</p><p class="text-xs font-bold text-slate-500">Cartons</p></div>
								<div class="rounded-2xl bg-white/60 p-3"><p class="text-xl font-black text-[#101820]">{Math.round(Number(order.total || 0))}€</p><p class="text-xs font-bold text-slate-500">Total</p></div>
								<div class="rounded-2xl bg-white/60 p-3"><p class="text-xl font-black text-[#101820]">{orderFlavors}</p><p class="text-xs font-bold text-slate-500">Goûts</p></div>
							</div>

							<div class="mt-5 rounded-[1.25rem] border border-black/10 bg-white/60 p-4">
								<p class="text-xs font-black uppercase tracking-[0.14em] text-[#116b4c]">Suivi commande</p>
								<div class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
									{orderTimeline(order).map((step) => (
										<div class="flex items-center gap-3">
											<span class={`flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-xs font-black ring-4 ${timelineDotClass(step.state)}`}>
												{step.state === "done" ? "✓" : step.state === "error" ? "!" : ""}
											</span>
											<span class={`text-xs font-black ${timelineTextClass(step.state)}`}>{step.label}</span>
										</div>
									))}
								</div>
								{order.payment_proof_status === "invalid" && order.payment_proof_rejection_reason && (
									<p class="mt-4 rounded-2xl bg-red-50 px-4 py-3 text-xs font-bold text-red-700">
										Preuve refusee: {order.payment_proof_rejection_reason}
									</p>
								)}
								{order.payment_method === "virement" && order.payment_proof_status === "invalid" && (
									<div class="mt-4 rounded-2xl border border-red-100 bg-white/80 p-4" data-proof-row data-order-id={order.id}>
										<p class="text-xs font-black uppercase tracking-[0.14em] text-red-700">Renvoyer une preuve</p>
										<div class="mt-3 flex flex-col gap-3 sm:flex-row sm:items-center">
											<input type="file" accept="image/png,image/jpeg,image/webp" class="rounded-2xl border border-black/10 bg-white px-3 py-2 text-xs font-bold text-slate-600" data-proof-input />
											<button type="button" class="btn-primary px-4 py-2 text-xs disabled:cursor-not-allowed disabled:opacity-60" data-proof-save>Envoyer la preuve</button>
										</div>
										<p class="mt-2 text-xs font-bold text-slate-500" data-proof-status>JPG, PNG ou WEBP, maximum 6 Mo.</p>
									</div>
								)}
							</div>

							<div class="mt-4 flex justify-end">
								<a href={`/precommande?repeatOrder=${order.id}`} class="btn-secondary px-4 py-2 text-xs">Recommande rapide</a>
							</div>

							{canEdit && (
								<div class="mt-4 rounded-2xl border border-[#28e08f]/40 bg-[#ecfff6] p-4 text-sm text-slate-700">
									<p class="text-xs font-black uppercase tracking-[0.14em] text-[#116b4c]">Précommande ouverte: modification possible</p>
									<div class="mt-3 flex flex-wrap items-center gap-3" data-order-row data-order-id={order.id}>
										<button type="button" class="flex h-9 w-9 items-center justify-center rounded-full bg-white text-lg font-black text-[#101820] shadow-sm" data-carton-dec>-</button>
										<span class="min-w-[2.5rem] text-center text-base font-black text-[#101820]" data-carton-value>{order.cartons}</span>
										<button type="button" class="flex h-9 w-9 items-center justify-center rounded-full bg-white text-lg font-black text-[#101820] shadow-sm" data-carton-inc>+</button>
										<button type="button" class="btn-primary px-4 py-2 text-xs disabled:cursor-not-allowed disabled:opacity-60" data-carton-save>Mettre à jour</button>
										<button type="button" class="rounded-full border border-red-200 bg-white px-4 py-2 text-xs font-black text-red-600 transition hover:-translate-y-0.5" data-order-delete>Supprimer</button>
										<span class="text-xs font-bold text-slate-500" data-carton-total></span>
									</div>
								</div>
							)}
						</article>
					);
				})}
			</section>
		</div>
	</main>
	<DashboardNav />

	<script type="module">
		(() => {
			const rows = document.querySelectorAll("[data-order-row]");
			const proofRows = document.querySelectorAll("[data-proof-row]");
			const root = document.querySelector("[data-price-per-carton]");
			const pricePerCarton = Number(root?.getAttribute("data-price-per-carton") || 0);
			const calcTotal = (cartons) => Math.round(cartons * pricePerCarton);
			rows.forEach((row) => {
				const orderId = row.getAttribute("data-order-id");
				const decBtn = row.querySelector("[data-carton-dec]");
				const incBtn = row.querySelector("[data-carton-inc]");
				const saveBtn = row.querySelector("[data-carton-save]");
				const valueEl = row.querySelector("[data-carton-value]");
				const totalEl = row.querySelector("[data-carton-total]");
				if (!orderId || !decBtn || !incBtn || !saveBtn || !valueEl) return;
				let cartons = Number(valueEl.textContent || 0) || 1;
				const updateTotal = () => {
					if (totalEl) totalEl.textContent = `Nouveau total: ${calcTotal(cartons)} EUR`;
				};
				updateTotal();
				decBtn.addEventListener("click", () => {
					cartons = Math.max(1, cartons - 1);
					valueEl.textContent = String(cartons);
					updateTotal();
				});
				incBtn.addEventListener("click", () => {
					cartons += 1;
					valueEl.textContent = String(cartons);
					updateTotal();
				});
				saveBtn.addEventListener("click", async () => {
					saveBtn.disabled = true;
					const originalText = saveBtn.textContent;
					saveBtn.textContent = "Mise à jour...";
					const response = await fetch("/api/update-order-cartons", {
						method: "POST",
						headers: { "Content-Type": "application/json" },
						body: JSON.stringify({ order_id: orderId, cartons })
					});
					const result = await response.json().catch(() => null);
					if (!response.ok || !result?.success) {
						alert(result?.error || "Impossible de mettre à jour la commande.");
						saveBtn.disabled = false;
						saveBtn.textContent = originalText || "Mettre à jour";
						return;
					}
					saveBtn.disabled = false;
					saveBtn.textContent = "Mis à jour";
					setTimeout(() => {
						saveBtn.textContent = originalText || "Mettre à jour";
					}, 1500);
					if (totalEl) totalEl.textContent = `Total mis à jour: ${result.total} EUR`;
				});
				const deleteBtn = row.querySelector("[data-order-delete]");
				if (deleteBtn) {
					deleteBtn.addEventListener("click", async () => {
						const confirmed = window.confirm("Supprimer cette commande ?");
						if (!confirmed) return;
						deleteBtn.disabled = true;
						const originalText = deleteBtn.textContent;
						deleteBtn.textContent = "Suppression...";
						const response = await fetch("/api/delete-order", {
							method: "POST",
							headers: { "Content-Type": "application/json" },
							body: JSON.stringify({ order_id: orderId })
						});
						const result = await response.json().catch(() => null);
						if (!response.ok || !result?.success) {
							alert(result?.error || "Impossible de supprimer la commande.");
							deleteBtn.disabled = false;
							deleteBtn.textContent = originalText || "Supprimer";
							return;
						}
						row.closest("article")?.remove();
					});
				}
			});

			proofRows.forEach((row) => {
				const orderId = row.getAttribute("data-order-id");
				const input = row.querySelector("[data-proof-input]");
				const button = row.querySelector("[data-proof-save]");
				const status = row.querySelector("[data-proof-status]");
				if (!orderId || !(input instanceof HTMLInputElement) || !(button instanceof HTMLButtonElement)) return;

				button.addEventListener("click", async () => {
					const file = input.files?.[0];
					if (!file) {
						if (status) status.textContent = "Ajoute une image avant d'envoyer.";
						return;
					}

					button.disabled = true;
					const initialText = button.textContent;
					button.textContent = "Envoi...";
					if (status) status.textContent = "Upload de la preuve...";

					try {
						const formData = new FormData();
						formData.append("proof", file);
						const uploadResponse = await fetch("/api/upload-payment-proof", {
							method: "POST",
							body: formData
						});
						const uploadResult = await uploadResponse.json().catch(() => null);
						if (!uploadResponse.ok || !uploadResult?.success || !uploadResult?.path) {
							throw new Error(uploadResult?.error || "Upload impossible.");
						}

						if (status) status.textContent = "Association a la commande...";
						const updateResponse = await fetch("/api/update-payment-proof", {
							method: "POST",
							headers: { "Content-Type": "application/json" },
							body: JSON.stringify({
								order_id: orderId,
								payment_proof_path: uploadResult.path
							})
						});
						const updateResult = await updateResponse.json().catch(() => null);
						if (!updateResponse.ok || !updateResult?.success) {
							throw new Error(updateResult?.error || "Mise a jour impossible.");
						}

						if (status) status.textContent = "Nouvelle preuve envoyee, verification en cours.";
						button.textContent = "Envoyee";
						setTimeout(() => window.location.reload(), 900);
					} catch (error) {
						if (status) status.textContent = error instanceof Error ? error.message : "Impossible d'envoyer la preuve.";
						button.disabled = false;
						button.textContent = initialText || "Envoyer la preuve";
					}
				});
			});
		})();
	</script>
</Layout>
